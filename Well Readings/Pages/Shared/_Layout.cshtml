<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Water Dashboard</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <header class="app-header">
        <div class="app-title">💧 Water Dashboard</div>

        <nav class="desktop-nav">
            <a href="/Scada">Home</a>
            <a href="/ScadaEntry">Enter Readings</a>
            <a href="/Maintenance">Maintenance</a>
            <a href="/DailyEntry">Entry Log</a>
            <a href="/MonthlyReport">Reports</a>
            <a href="/ExcelImport">Import</a>
            <a href="/DistributionPoints">Distribution</a>
                        
        </nav>

        <div class="mobile-nav">
            <select onchange="if (this.value) window.location.href = this.value;">
                <option value="">Menu</option>
                <a href="/Scada">Home</a>
                <a href="/ScadaEntry">Enter Readings</a>
                <a href="/Maintenance">Maintenance</a>
                <a href="/DailyEntry">Entry Log</a>
                <a href="/MonthlyReport">Reports</a>
                <a href="/ExcelImport">Import</a>
                <a href="/DistributionPoints">Distribution</a>
                
           
            </select>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <script>
        const currentPath = window.location.pathname.toLowerCase();

        document.querySelectorAll(".desktop-nav a").forEach(link => {
            const linkPath = link.getAttribute("href").toLowerCase();

            if (linkPath === currentPath) {
                link.classList.add("active");
            }
        });

        const mobileMenu = document.querySelector(".mobile-nav select");

        if (mobileMenu) {
            Array.from(mobileMenu.options).forEach(option => {
                if (option.value && option.value.toLowerCase() === currentPath) {
                    mobileMenu.value = option.value;
                }
            });
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>