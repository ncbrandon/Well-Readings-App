<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Water Dashboard</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <header class="app-header">
        <div class="app-title">💧 Water Dashboard</div>

        <nav class="desktop-nav">
            <a href="/Scada">Home</a>
            <a href="/ScadaEntry">Daily</a>
            <a href="/Maintenance">Maintenance</a>
            <a href="/DailyEntry">Log</a>
            <a href="/MonthlyReport">Reports</a>
        </nav>

        <div class="mobile-nav">
            <select onchange="if (this.value) window.location.href = this.value;">
                <option value="">Menu</option>
                <option value="/Scada">Home</option>
                <option value="/ScadaEntry">Daily</option>
                <option value="/Maintenance">Maintenance</option>
                <option value="/DailyEntry">Log</option>
                <option value="/MonthlyReport">Reports</option>
            </select>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>