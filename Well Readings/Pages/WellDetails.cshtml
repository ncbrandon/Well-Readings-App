@page
@model Well_Readings.Pages.WellDetailsModel

<h2>@Model.Name</h2>

<table>
    <thead>
        <tr>
            <th>Date</th>
            <th>Gallons</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model.Readings)
        {
            <tr>
                <td>@r.Date</td>
                <td>@r.Gallons</td>
            </tr>
        }
    </tbody>
</table>
