@page
@model Well_Readings.Pages.DailyEntryEditModel

<h1>Edit Daily Entry</h1>

<div class="entry-header">
    <label>Date:</label>
    <input type="date" id="entryDate" />

    <label>Time:</label>
    <input type="time" id="entryTime" step="1" />
</div>

<div id="entryPanel" class="entry-panel"></div>

<button type="button" class="save-btn" onclick="saveEntry()">Save Changes</button>
<a class="back-link" href="/DailyEntry">Back to Daily Entries</a>

<div id="message"></div>

<style>
    .entry-header {
        margin-bottom: 20px;
        color: #111827;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

        .entry-header label {
            font-weight: bold;
        }

        .entry-header input {
            padding: 8px;
            border: 1px solid #374151;
            border-radius: 6px;
            color: #111827;
            background: white;
        }

    .entry-panel {
        background: #f3f4f6;
        color: #111827;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 25px;
    }

    .entry-group {
        background: white;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
    }

        .entry-group h2 {
            color: #111827;
            border-bottom: 2px solid #047857;
            padding-bottom: 6px;
        }

    .field-row {
        margin-bottom: 12px;
    }

        .field-row label {
            display: inline-block;
            width: 300px;
            font-weight: bold;
            color: #111827;
        }

        .field-row input {
            padding: 8px;
            width: 160px;
            color: #111827;
            background: white;
            border: 1px solid #374151;
            border-radius: 5px;
        }

    .save-btn {
        padding: 12px 24px;
        font-weight: bold;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
    }

    .back-link {
        display: inline-block;
        margin-left: 15px;
        color: #2563eb;
        font-weight: bold;
    }

    #message {
        margin-top: 20px;
        font-weight: bold;
        color: #111827;
    }
</style>

<script>
    const originalTimestamp = new URLSearchParams(window.location.search).get("timestamp");

    const fieldGroups = [
        {
            groupName: "Reeves Well Site",
            fields: [
                { label: "Reeves Well Meter", location: "Reeves Well", metricType: "Meter Reading", sourceColumn: "Reeves Well" },
                { label: "Reeves Well A Meter", location: "Reeves Well A", metricType: "Meter Reading", sourceColumn: "Reeves Well A" },
                { label: "Chlorine", location: "Reeves Well Site", metricType: "Chlorine", sourceColumn: "Cl-R" },
                { label: "Phosphate", location: "Reeves Well Site", metricType: "Phosphate", sourceColumn: "PO4-R" },
                { label: "pH", location: "Reeves Well Site", metricType: "pH", sourceColumn: "pH-R" }
            ]
        },
        {
            groupName: "Park Well Site",
            fields: [
                { label: "Park Well Meter", location: "Park Well", metricType: "Meter Reading", sourceColumn: "Park Well" },
                { label: "Park Well A Meter", location: "Park Well A", metricType: "Meter Reading", sourceColumn: "Park Well A" },
                { label: "Park Well B Meter", location: "Park Well B", metricType: "Meter Reading", sourceColumn: "Park Well B" },
                { label: "Chlorine", location: "Park Well Site", metricType: "Chlorine", sourceColumn: "Cl-P" },
                { label: "Phosphate", location: "Park Well Site", metricType: "Phosphate", sourceColumn: "PO4-P" },
                { label: "pH", location: "Park Well Site", metricType: "pH", sourceColumn: "pH-P" }
            ]
        },
        {
            groupName: "Woods",
            fields: [
                { label: "Meter Reading", location: "Woods", metricType: "Meter Reading", sourceColumn: "Woods" },
                { label: "Chlorine", location: "Woods", metricType: "Chlorine", sourceColumn: "Cl-W" },
                { label: "Phosphate", location: "Woods", metricType: "Phosphate", sourceColumn: "PO4-W" },
                { label: "pH", location: "Woods", metricType: "pH", sourceColumn: "pH-W" }
            ]
        },
        {
            groupName: "Catawissa",
            fields: [
                { label: "Meter Reading", location: "Catawissa", metricType: "Meter Reading", sourceColumn: "Catawissa" },
                { label: "Chlorine", location: "Catawissa", metricType: "Chlorine", sourceColumn: "Cl-C" },
                { label: "Phosphate", location: "Catawissa", metricType: "Phosphate", sourceColumn: "PO4-C" },
                { label: "pH", location: "Catawissa", metricType: "pH", sourceColumn: "pH-C" }
            ]
        },
        {
            groupName: "New",
            fields: [
                { label: "Meter Reading", location: "New", metricType: "Meter Reading", sourceColumn: "New" },
                { label: "Chlorine", location: "New", metricType: "Chlorine", sourceColumn: "Cl-N" },
                { label: "Phosphate", location: "New", metricType: "Phosphate", sourceColumn: "PO4-N" },
                { label: "pH", location: "New", metricType: "pH", sourceColumn: "pH-N" }
            ]
        },
        {
            groupName: "Oakwood",
            fields: [
                { label: "Meter Reading", location: "Oakwood", metricType: "Meter Reading", sourceColumn: "Oakwood" },
                { label: "Chlorine", location: "Oakwood", metricType: "Chlorine", sourceColumn: "Cl-O" },
                { label: "Phosphate", location: "Oakwood", metricType: "Phosphate", sourceColumn: "PO4-O" },
                { label: "pH", location: "Oakwood", metricType: "pH", sourceColumn: "pH-O" }
            ]
        },
        {
            groupName: "Ray",
            fields: [
                { label: "Meter Reading", location: "Ray", metricType: "Meter Reading", sourceColumn: "Ray" },
                { label: "Chlorine", location: "Ray", metricType: "Chlorine", sourceColumn: "Cl-Ray" },
                { label: "Phosphate", location: "Ray", metricType: "Phosphate", sourceColumn: "PO4-Ray" },
                { label: "pH", location: "Ray", metricType: "pH", sourceColumn: "pH-Ray" }
            ]
        },
        {
            groupName: "Filter 1",
            fields: [
                { label: "Feed Pressure", location: "Filter 1", metricType: "Feed Pressure", sourceColumn: "Filter 1 Feed Pressure" },
                { label: "Feed Flow", location: "Filter 1", metricType: "Feed Flow", sourceColumn: "Filter 1 Feed Flow" },
                { label: "Filtrate Pressure", location: "Filter 1", metricType: "Filtrate Pressure", sourceColumn: "Filter 1 Filtrate Pressure" },
                { label: "Filtrate Flow", location: "Filter 1", metricType: "Filtrate Flow", sourceColumn: "Filter 1 Filtrate Flow" },
                { label: "TMP", location: "Filter 1", metricType: "TMP", sourceColumn: "Filter 1 TMP" },
                { label: "Total Filter Run Time", location: "Filter 1", metricType: "Total Filter Run Time", sourceColumn: "Filter 1 Total Filter Run Time" },
                { label: "Total Filtration Flow Yesterday", location: "Filter 1", metricType: "Total Filtration Flow Yesterday", sourceColumn: "Filter 1 Total Filtration Flow Yesterday" },
                { label: "Pressure Decay", location: "Filter 1", metricType: "Pressure Decay", sourceColumn: "Filter 1 Pressure Decay" }
            ]
        },
        {
            groupName: "Filter 2",
            fields: [
                { label: "Feed Pressure", location: "Filter 2", metricType: "Feed Pressure", sourceColumn: "Filter 2 Feed Pressure" },
                { label: "Feed Flow", location: "Filter 2", metricType: "Feed Flow", sourceColumn: "Filter 2 Feed Flow" },
                { label: "Filtrate Pressure", location: "Filter 2", metricType: "Filtrate Pressure", sourceColumn: "Filter 2 Filtrate Pressure" },
                { label: "Filtrate Flow", location: "Filter 2", metricType: "Filtrate Flow", sourceColumn: "Filter 2 Filtrate Flow" },
                { label: "TMP", location: "Filter 2", metricType: "TMP", sourceColumn: "Filter 2 TMP" },
                { label: "Total Filter Run Time", location: "Filter 2", metricType: "Total Filter Run Time", sourceColumn: "Filter 2 Total Filter Run Time" },
                { label: "Total Filtration Flow Yesterday", location: "Filter 2", metricType: "Total Filtration Flow Yesterday", sourceColumn: "Filter 2 Total Filtration Flow Yesterday" },
                { label: "Pressure Decay", location: "Filter 2", metricType: "Pressure Decay", sourceColumn: "Filter 2 Pressure Decay" }
            ]
        },
        {
            groupName: "Filter Plant",
            fields: [
                { label: "Meter Reading", location: "Filter Plant", metricType: "Meter Reading", sourceColumn: "Filter Plant" },
                { label: "Chlorine", location: "Filter Plant", metricType: "Chlorine", sourceColumn: "Cl-F" },
                { label: "Phosphate", location: "Filter Plant", metricType: "Phosphate", sourceColumn: "PO4-F" },
                { label: "pH", location: "Filter Plant", metricType: "pH", sourceColumn: "pH-F" },
                { label: "Temperature", location: "Filter Plant", metricType: "Temperature", sourceColumn: "Temp-F" },
                { label: "Mt. Jefferson Meter", location: "Mt. Jefferson", metricType: "Meter Reading", sourceColumn: "Mt. Jefferson" },
                { label: "Pump Flow", location: "Pump Stations", metricType: "Flow", sourceColumn: "Pump Flow" },
                { label: "Pressure", location: "Pump Stations", metricType: "Pressure", sourceColumn: "Pump Pressure" }
            ]
        }
    ];

    const values = {};

    async function loadEntry() {
        if (!originalTimestamp) {
            document.getElementById("message").innerText = "No timestamp was provided.";
            return;
        }

        const originalDate = new Date(originalTimestamp);
        document.getElementById("entryDate").value = originalDate.toISOString().slice(0, 10);
        document.getElementById("entryTime").value = originalDate.toTimeString().slice(0, 8);

        const response = await fetch(`/api/scada/daily-entry?timestamp=${encodeURIComponent(originalTimestamp)}`);

        if (!response.ok) {
            document.getElementById("message").innerText = "Error loading daily entry.";
            return;
        }

        const entries = await response.json();

        entries.forEach(item => {
            const key = `${item.location}|${item.metricType}|${item.sourceColumn}`;
            values[key] = item.value;
        });

        renderFields();
    }

    function renderFields() {
        const panel = document.getElementById("entryPanel");

        panel.innerHTML = fieldGroups.map(group => `
            <div class="entry-group">
                <h2>${group.groupName}</h2>

                ${group.fields.map(field => {
                    const key = `${field.location}|${field.metricType}|${field.sourceColumn}`;
                    const value = values[key] ?? "";

                    return `
                        <div class="field-row">
                            <label>${field.label}</label>
                            <input
                                type="number"
                                step="0.01"
                                value="${value}"
                                data-location="${field.location}"
                                data-metric="${field.metricType}"
                                data-source="${field.sourceColumn}" />
                        </div>
                    `;
                }).join("")}
            </div>
        `).join("");
    }

    async function saveEntry() {
        const date = document.getElementById("entryDate").value;
        const time = document.getElementById("entryTime").value;

        if (!date || !time) {
            alert("Please enter both date and time.");
            return;
        }

        const newTimestamp = new Date(`${date}T${time}`).toISOString();

        const inputs = document.querySelectorAll("#entryPanel input");
        const readings = [];

        inputs.forEach(input => {
            readings.push({
                location: input.dataset.location,
                metricType: input.dataset.metric,
                sourceColumn: input.dataset.source,
                value: input.value === "" ? null : parseFloat(input.value)
            });
        });

        const response = await fetch("/api/scada/daily-entry/update", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                originalTimestamp: originalTimestamp,
                timestamp: newTimestamp,
                readings: readings
            })
        });

        const message = document.getElementById("message");

        if (response.ok) {
            message.innerText = "Daily entry updated successfully.";
            message.style.color = "#047857";
        } else {
            message.innerText = "Error updating daily entry.";
            message.style.color = "#b91c1c";
        }
    }

    loadEntry();
</script>