@page "/DailyEntryEdit"
@model Well_Readings.Pages.DailyEntryEditModel

<h1>Edit Daily Entry</h1>

<div class="top-bar">
    <button type="button" class="edit-btn" onclick="enableEditMode()">
        Enable Editing
    </button>

    <button type="button" class="save-btn" onclick="saveAllChanges()" id="saveButton" disabled>
        Save Changes
    </button>
</div>

<div id="message"></div>

<table class="entry-table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Time</th>
            <th>Location</th>
            <th>Metric</th>
            <th>Value</th>
        </tr>
    </thead>

    <tbody id="entriesBody"></tbody>
</table>

<style>
    .top-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

    .edit-btn {
        background: #2563eb;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
    }

    .save-btn {
        background: #047857;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
    }

        .save-btn:disabled {
            background: #9ca3af;
            cursor: not-allowed;
        }

    .entry-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        color: #111827;
    }

        .entry-table th,
        .entry-table td {
            border: 1px solid #d1d5db;
            padding: 10px;
            text-align: left;
        }

        .entry-table th {
            background: #1f2937;
            color: white;
        }

        .entry-table tbody tr:nth-child(even) {
            background: #eff6ff;
        }

        .entry-table input {
            width: 100%;
            padding: 6px;
            border: 1px solid #9ca3af;
            border-radius: 6px;
        }

            .entry-table input:disabled {
                background: #f3f4f6;
                color: #6b7280;
            }

    #message {
        margin-bottom: 15px;
        font-weight: bold;
    }

    @@media (max-width: 900px) {
        .entry-table {
            font-size: 12px;
        }
    }
</style>

<script>
    let entries = [];
    let editMode = false;

    const urlParams = new URLSearchParams(window.location.search);
    const timestamp = urlParams.get("timestamp");

    async function loadEntry() {
        if (!timestamp) {
            showError("Missing timestamp.");
            return;
        }

        const response = await fetch(`/api/scada/daily-entry?timestamp=${encodeURIComponent(timestamp)}`);

        if (!response.ok) {
            showError("Unable to load entry.");
            return;
        }

        entries = await response.json();

        renderTable();
    }

    function renderTable() {
        const body = document.getElementById("entriesBody");
        body.innerHTML = "";

        if (!entries || entries.length === 0) {
            body.innerHTML = `
                <tr>
                    <td colspan="5">No entry data found.</td>
                </tr>
            `;
            return;
        }

        entries.forEach((entry, index) => {
            const timestamp = new Date(entry.timestamp);

            const dateValue =
                timestamp.getFullYear() + "-" +
                String(timestamp.getMonth() + 1).padStart(2, "0") + "-" +
                String(timestamp.getDate()).padStart(2, "0");

            const timeValue =
                String(timestamp.getHours()).padStart(2, "0") + ":" +
                String(timestamp.getMinutes()).padStart(2, "0") + ":" +
                String(timestamp.getSeconds()).padStart(2, "0");

            const row = document.createElement("tr");

            row.innerHTML = `
                <td>
                    <input type="date"
                           value="${dateValue}"
                           onchange="updateDate(${index}, this.value)"
                           ${editMode ? "" : "disabled"} />
                </td>

                <td>
                    <input type="time"
                           step="1"
                           value="${timeValue}"
                           onchange="updateTime(${index}, this.value)"
                           ${editMode ? "" : "disabled"} />
                </td>

                <td>${entry.location}</td>

                <td>${entry.metricType}</td>

                <td>
                    <input type="number"
                           step="0.001"
                           value="${entry.value ?? ''}"
                           onchange="updateValue(${index}, this.value)"
                           ${editMode ? "" : "disabled"} />
                </td>
            `;

            body.appendChild(row);
        });
    }

    function enableEditMode() {
        editMode = true;

        document.getElementById("saveButton").disabled = false;

        renderTable();
    }

    function updateDate(index, value) {
        const existing = new Date(entries[index].timestamp);

        const time =
            String(existing.getHours()).padStart(2, "0") + ":" +
            String(existing.getMinutes()).padStart(2, "0") + ":" +
            String(existing.getSeconds()).padStart(2, "0");

        entries[index].timestamp = `${value}T${time}`;
    }

    function updateTime(index, value) {
        const existing = new Date(entries[index].timestamp);

        const date =
            existing.getFullYear() + "-" +
            String(existing.getMonth() + 1).padStart(2, "0") + "-" +
            String(existing.getDate()).padStart(2, "0");

        entries[index].timestamp = `${date}T${value}`;
    }

    function updateValue(index, value) {
        entries[index].value = value === "" ? null : parseFloat(value);
    }

    async function saveAllChanges() {
        const response = await fetch("/api/scada/update-daily-entry", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(entries)
        });

        if (response.ok) {
            showSuccess("Changes saved successfully.");

            editMode = false;

            document.getElementById("saveButton").disabled = true;

            await loadEntry();
        } else {
            const error = await response.text();
            showError("Error saving changes: " + error);
        }
    }

    function showSuccess(message) {
        const el = document.getElementById("message");
        el.innerText = message;
        el.style.color = "#047857";
    }

    function showError(message) {
        const el = document.getElementById("message");
        el.innerText = message;
        el.style.color = "#b91c1c";
    }

    loadEntry();
</script>