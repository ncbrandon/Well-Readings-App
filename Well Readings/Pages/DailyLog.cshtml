@page
@model Well_Readings.Pages.DailyLogModel

<h2 class="mb-3">Daily Log</h2>

@if (Model.Entries == null || !Model.Entries.Any())
{
    <div class="alert alert-warning">No daily entries found.</div>
}
else
{
    <div class="card card-dashboard p-3">

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Wells</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td>
                            <a asp-page="/DailyEntry" asp-route-id="@entry.Id">
                                @entry.EntryDate.ToString("yyyy-MM-dd")
                            </a>
                        </td>

                        <td>
                            <a asp-page="/DailyEntry" asp-route-id="@entry.Id">
                                @entry.EntryTime.ToString("HH:mm")
                            </a>
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                @entry.WellCount wells
                            </span>
                        </td>

                        <td class="text-end">
                            <form method="post"
                                  asp-page-handler="Delete"
                                  asp-route-id="@entry.Id"
                                  onsubmit="return confirm('Delete this entry?');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
}
