<script>
        setDefaultDates();

        function toggleReportSection(sectionId) {
            const selected = document.getElementById(sectionId);
            const allSections = document.querySelectorAll(".report-section");

            allSections.forEach(section => {
                if (section.id === sectionId) {
                    section.classList.toggle("is-open");
                } else {
                    section.classList.remove("is-open");
                }
            });
        }
        
        function setDefaultDates() {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);

            document.getElementById("siteStartDate").valueAsDate = firstDay;
            document.getElementById("siteEndDate").valueAsDate = today;
            document.getElementById("meterStartDate").valueAsDate = firstDay;
            document.getElementById("meterEndDate").valueAsDate = today;
            document.getElementById("consumptionLastReadDate").valueAsDate = firstDay;
            document.getElementById("consumptionCurrentReadDate").valueAsDate = today;
            document.getElementById("consumptionHistoryYear").value = today.getFullYear();
            document.getElementById("pumpStartDate").valueAsDate = firstDay;
            document.getElementById("pumpEndDate").valueAsDate = today;
            document.getElementById("ncMorStartDate").valueAsDate = firstDay;
            document.getElementById("ncMorEndDate").valueAsDate = today;
        }

        async function loadSiteReport() {
            const site = document.getElementById("siteSelect").value;
            const startDate = document.getElementById("siteStartDate").value;
            const endDate = document.getElementById("siteEndDate").value;

            if (!startDate || !endDate) {
                alert("Please select a beginning and ending date.");
                return;
            }

            const response = await fetch(`/api/scada/monthly-site-report?site=${encodeURIComponent(site)}&startDate=${startDate}&endDate=${endDate}`);

            if (!response.ok) {
                alert("Error loading monthly report.");
                return;
            }

            const data = await response.json();

            renderSiteRows(data.rows || []);
            renderSummaryRows(data.summary || []);
        }

        function renderSiteRows(rows) {
            const body = document.getElementById("siteReportBody");
            body.innerHTML = "";

