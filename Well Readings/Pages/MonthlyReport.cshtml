@page
@model Well_Readings.Pages.MonthlyReportModel

<h1>Monthly Reports</h1>

<section class="report-card report-section is-open" id="siteMonthlyReportSection">
    <button type="button" class="report-section-header" onclick="toggleReportSection('siteMonthlyReportSection')">
        <span class="report-section-title">
            <span>Site Monthly Report</span>
            <span class="report-section-subtitle">Daily gallons, chemistry, and site summary</span>
        </span>
        <span class="report-section-arrow">⌄</span>
    </button>

    <div class="report-section-content">

    <div class="filter-row">
        <label>Site</label>
        <select id="siteSelect">
            <option>All Sites</option>
            <option>Reeves Well Site</option>
            <option>Park Well Site</option>
            <option>Woods</option>
            <option>Catawissa</option>
            <option>New</option>
            <option>Oakwood</option>
            <option>Ray</option>
            <option>Mt. Jefferson</option>
            <option>Filter Plant</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="siteStartDate" />

        <label>Ending Date</label>
        <input type="date" id="siteEndDate" />

        <button type="button" onclick="loadSiteReport()">Run Report</button>
    </div>

    <h3>Daily Results</h3>

    <table class="report-table">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Site</th>
                <th>Well / Filter</th>
                <th>Gallons Pumped</th>
                <th>Chlorine</th>
                <th>Phosphate</th>
                <th>pH</th>
                <th>Temperature</th>
            </tr>
        </thead>
        <tbody id="siteReportBody"></tbody>
    </table>

    <h3>Summary</h3>

    <table class="report-table">
        <thead>
            <tr>
                <th>Site</th>
                <th>Well / Filter</th>
                <th>Days Pumped</th>
                <th>Max Gallons Pumped</th>
                <th>Total Gallons Pumped</th>
            </tr>
        </thead>
        <tbody id="summaryBody"></tbody>
    </table>
    </div>
</section>

<section class="report-card report-section" id="meterReadingReportSection">
    <button type="button" class="report-section-header" onclick="toggleReportSection('meterReadingReportSection')">
        <span class="report-section-title">
            <span>Meter Reading Report</span>
            <span class="report-section-subtitle">Total gallons pumped for a selected date range</span>
        </span>
        <span class="report-section-arrow">⌄</span>
    </button>

    <div class="report-section-content">

    <div class="meter-filter-row">
        <label>Beginning Date</label>
        <input type="date" id="meterStartDate" />

        <label>Ending Date</label>

        <div class="meter-ending-box">
            <input type="date" id="meterEndDate" />
            <div class="meter-warning">DAY AFTER METERS READ</div>
        </div>

        <button type="button" onclick="loadMeterTotalReport()">Run Total Report</button>
    </div>

    <div class="total-box">
        Total Gallons Pumped:
        <span id="totalGallons">0</span>
    </div>
    </div>
</section>

<section class="report-card consumption-card report-section" id="consumptionReportSection">
    <button type="button" class="report-section-header" onclick="toggleReportSection('consumptionReportSection')">
        <span class="report-section-title">
            <span>Consumption Report</span>
            <span class="report-section-subtitle">Compare pumped water to customer meter consumption</span>
        </span>
        <span class="report-section-arrow">⌄</span>
    </button>

    <div class="report-section-content">

    <p class="help-text">
        Compare customer meter consumption against total water pumped between meter reading dates.
    </p>

    <div class="filter-row">
        <label>Previous Meter Read Date</label>
        <input type="date" id="consumptionLastReadDate" />

        <label>Current Meter Read Date</label>
        <input type="date" id="consumptionCurrentReadDate" />

        <label>Total Consumer Gallons</label>
        <input type="number" id="consumerGallons" placeholder="Example: 5147670" min="0" step="1" />

        <button type="button" onclick="loadConsumptionReport()">Run Report</button>
        <button type="button" onclick="saveConsumptionReport()">Save Report</button>
        <button type="button" onclick="exportConsumptionReport()">Export Current</button>
    </div>

    <label class="notes-label">Notes / Known Issues</label>
    <textarea id="consumptionNotes" class="notes-box" placeholder="Known leak repaired, hydrant flushing, main break, meter issue, etc."></textarea>

    <div id="consumptionWarning" class="consumption-warning consumption-warning-neutral">
        Enter the billing meter read dates and total consumer gallons, then run the report.
    </div>

    <div class="consumption-kpi-grid">
        <div class="consumption-kpi">
            <div class="consumption-kpi-label">Water Pumped</div>
            <div class="consumption-kpi-value" id="consumptionPumped">0</div>
        </div>

        <div class="consumption-kpi">
            <div class="consumption-kpi-label">Water Consumed</div>
            <div class="consumption-kpi-value" id="consumptionConsumed">0</div>
        </div>

        <div class="consumption-kpi">
            <div class="consumption-kpi-label">Unaccounted For</div>
            <div class="consumption-kpi-value" id="consumptionLoss">0</div>
        </div>

        <div class="consumption-kpi">
            <div class="consumption-kpi-label">% Loss</div>
            <div class="consumption-kpi-value" id="consumptionLossPercent">0%</div>
        </div>
    </div>

    <div class="consumption-detail-grid">
        <div><strong>Billing Days:</strong> <span id="consumptionBillingDays">0</span></div>
        <div><strong>Pumped Avg/Day:</strong> <span id="consumptionPumpedAvg">0</span></div>
        <div><strong>Consumed Avg/Day:</strong> <span id="consumptionConsumedAvg">0</span></div>
        <div><strong>Date Range:</strong> <span id="consumptionDateRange">-</span></div>
    </div>

    <div class="consumption-chart-wrap">
        <canvas id="consumptionChart"></canvas>
    </div>

    <hr />

    <h3>Import / History / Export</h3>

    <div class="filter-row">
        <label>Import Spreadsheet</label>
        <input type="file" id="consumptionImportFile" accept=".xlsx" />

        <button type="button" onclick="importConsumptionReports()">Import Historical Reports</button>
    </div>

    <div class="filter-row">
        <label>Export Year</label>
        <input type="number" id="consumptionHistoryYear" min="2000" max="2100" />

        <label>Start Month</label>
        <select id="consumptionStartMonth">
            <option value="">All</option>
            <option value="1">January</option>
            <option value="2">February</option>
            <option value="3">March</option>
            <option value="4">April</option>
            <option value="5">May</option>
            <option value="6">June</option>
            <option value="7">July</option>
            <option value="8">August</option>
            <option value="9">September</option>
            <option value="10">October</option>
            <option value="11">November</option>
            <option value="12">December</option>
        </select>

        <label>End Month</label>
        <select id="consumptionEndMonth">
            <option value="">All</option>
            <option value="1">January</option>
            <option value="2">February</option>
            <option value="3">March</option>
            <option value="4">April</option>
            <option value="5">May</option>
            <option value="6">June</option>
            <option value="7">July</option>
            <option value="8">August</option>
            <option value="9">September</option>
            <option value="10">October</option>
            <option value="11">November</option>
            <option value="12">December</option>
        </select>

        <button type="button" onclick="loadConsumptionHistory()">Load History</button>
        <button type="button" onclick="exportConsumptionHistory()">Export History</button>
    </div>

    <div class="consumption-chart-wrap">
        <canvas id="consumptionHistoryChart"></canvas>
    </div>

    <table class="report-table">
        <thead>
            <tr>
                <th>Period</th>
                <th>Last Read</th>
                <th>Current Read</th>
                <th>Days</th>
                <th>Pumped</th>
                <th>Consumed</th>
                <th>Loss</th>
                <th>Loss %</th>
                <th>Notes</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="consumptionHistoryBody"></tbody>
    </table>
    </div>
</section>


<section class="report-card report-section" id="pumpStationReportSection">
    <button type="button" class="report-section-header" onclick="toggleReportSection('pumpStationReportSection')">
        <span class="report-section-title">
            <span>Pump Station Report</span>
            <span class="report-section-subtitle">Pump run hours and entered pump station readings</span>
        </span>
        <span class="report-section-arrow">⌄</span>
    </button>

    <div class="report-section-content">

    <div class="filter-row">
        <label>Pump Station</label>
        <select id="pumpStationSelect">
            <option value="Beaver Creek">Beaver Creek</option>
            <option value="Greenfield">Greenfield</option>
            <option value="Helen Blevins">Helen Blevins</option>
            <option value="Dogget">Dogget</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="pumpStartDate" />

        <label>Ending Date</label>
        <input type="date" id="pumpEndDate" />

        <button type="button" onclick="loadPumpStationReport()">Run Pump Station Report</button>
    </div>

    <table class="report-table">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Station</th>
                <th>Pump</th>
                <th>Reading Entered</th>
                <th>Hours Run</th>
            </tr>
        </thead>
        <tbody id="pumpStationReportBody"></tbody>
    </table>
    </div>
</section>

<section class="report-card report-section" id="ncMorReportSection">
    <button type="button" class="report-section-header" onclick="toggleReportSection('ncMorReportSection')">
        <span class="report-section-title">
            <span>NC MOR Autofill Report</span>
            <span class="report-section-subtitle">Generate report data for the state MOR form</span>
        </span>
        <span class="report-section-arrow">⌄</span>
    </button>

    <div class="report-section-content">

    <div class="filter-row">
        <label>Site</label>
        <select id="ncMorSite">
            <option value="Reeves Well Site">Reeves Well Site</option>
            <option value="Park Well Site">Park Well Site</option>
            <option value="Woods">Woods</option>
            <option value="Catawissa">Catawissa</option>
            <option value="New">New</option>
            <option value="Oakwood">Oakwood</option>
            <option value="Ray">Ray</option>
            <option value="Filter Plant">Filter Plant</option>
            <option value="Distribution Points">Distribution Points</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="ncMorStartDate" />

        <label>Ending Date</label>
        <input type="date" id="ncMorEndDate" />

        <button type="button" onclick="generateNcMorScript()">Generate NC MOR Script</button>
        <button type="button" onclick="copyNcMorScript()">Copy Script</button>
    </div>

    <p class="help-text">
        Generate the script, copy it, paste it into the NC MOR console, and wait at least 10 seconds after it finishes.
    </p>

    <textarea id="ncMorScript" class="script-box"></textarea>
    </div>
</section>

