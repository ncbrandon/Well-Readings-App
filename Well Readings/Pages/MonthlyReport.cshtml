        async function importConsumptionReports() {
            const fileInput = document.getElementById("consumptionImportFile");

            if (!fileInput.files || fileInput.files.length === 0) {
                alert("Please choose a spreadsheet to import.");
                return;
            }

            const formData = new FormData();
            formData.append("file", fileInput.files[0]);

            const response = await fetch("/api/scada/consumption-report-import", {
                method: "POST",
                body: formData
            });

            if (!response.ok) {
                alert("Import failed.");
                return;
            }

            const result = await response.json();

            alert(`Import complete. Imported: ${result.imported}. Skipped: ${result.skipped}.`);

            await loadConsumptionHistory();
        }

        async function loadConsumptionHistory() {
            const year = document.getElementById("consumptionHistoryYear").value;
            const startMonth = document.getElementById("consumptionStartMonth").value;
            const endMonth = document.getElementById("consumptionEndMonth").value;

            let url = "/api/scada/consumption-report-history?";
            const params = [];

            if (year) params.push(`year=${encodeURIComponent(year)}`);
            if (startMonth) params.push(`startMonth=${encodeURIComponent(startMonth)}`);
            if (endMonth) params.push(`endMonth=${encodeURIComponent(endMonth)}`);

            url += params.join("&");

            const response = await fetch(url);

            if (!response.ok) {
                alert("Error loading consumption history.");
                return;
            }

            const rows = await response.json();

            renderConsumptionHistory(rows);
        }

                function renderConsumptionHistory(rows) {
            const body = document.getElementById("consumptionHistoryBody");
            body.innerHTML = "";

            if (!rows || rows.length === 0) {
                body.innerHTML = `<tr><td colspan="10">No saved consumption reports found.</td></tr>`;
                renderConsumptionHistoryChart([]);
                return;
            }

            rows.forEach(row => {
                const tr = document.createElement("tr");

                tr.innerHTML = `
                    <td>${row.periodLabel}</td>
                    <td>${formatShortDate(row.lastReadDate)}</td>
                    <td>${formatShortDate(row.currentReadDate)}</td>
                    <td>${row.billingDays}</td>
                    <td>${formatNumber(row.waterPumped)}</td>
                    <td>${formatNumber(row.waterConsumed)}</td>
                    <td>${formatNumber(row.waterLoss)}</td>
                    <td>${formatPercent(row.lossPercent)}</td>
                    <td>${row.notes ?? ""}</td>
                    <td>
                        <button type="button" class="delete-consumption-btn" onclick="deleteConsumptionReport('${row.id}')">
                            Delete
                        </button>
                    </td>
                `;

                body.appendChild(tr);
            });

            renderConsumptionHistoryChart(rows);
        }

                function renderConsumptionHistoryChart(rows) {
            const ctx = document.getElementById("consumptionHistoryChart");

            if (consumptionHistoryChart) {
                consumptionHistoryChart.destroy();
            }

            const labels = rows.map(x => x.periodLabel);

            consumptionHistoryChart = new Chart(ctx, {
                data: {
                    labels: labels,
                    datasets: [
                        {
                            type: "bar",
                            label: "Water Pumped",
                            data: rows.map(x => x.waterPumped),
                            backgroundColor: "#2563eb",
                            borderColor: "#1d4ed8",
                            borderWidth: 1,
                            yAxisID: "y"
                        },
                        {
                            type: "bar",
                            label: "Water Consumed",
                            data: rows.map(x => x.waterConsumed),
                            backgroundColor: "#059669",
                            borderColor: "#047857",
                            borderWidth: 1,
                            yAxisID: "y"
                        },
                        {
                            type: "bar",
                            label: "Unaccounted For",
                            data: rows.map(x => x.waterLoss),
                            backgroundColor: rows.map(x => {
                                const lossPercent = Number(x.lossPercent || 0);

                                if (lossPercent >= 0.30) {
                                    return "#dc2626";
                                }

                                if (lossPercent >= 0.20) {
                                    return "#f59e0b";
                                }

                                return "#64748b";
                            }),
                            borderColor: "#334155",
                            borderWidth: 1,
                            yAxisID: "y"
                        },
                        {
                            type: "line",
                            label: "Loss %",
                            data: rows.map(x => Number(x.lossPercent || 0) * 100),
                            borderColor: "#991b1b",
                            backgroundColor: "#991b1b",
                            borderWidth: 3,
                            tension: 0.25,
                            pointRadius: 5,
                            pointHoverRadius: 7,
                            yAxisID: "y1"
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: "index",
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            position: "top",
                            labels: {
                                color: "#111827",
                                font: {
                                    weight: "bold"
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    if (context.dataset.label === "Loss %") {
                                        return `Loss %: ${Number(context.raw).toFixed(2)}%`;
                                    }

                                    return `${context.dataset.label}: ${formatNumber(context.raw)} gallons`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: "#111827",
                                maxRotation: 45,
                                minRotation: 45,
                                font: {
                                    weight: "bold"
                                }
                            },
                            grid: {
                                color: "rgba(0,0,0,0.08)"
                            }
                        },
                        y: {
                            beginAtZero: true,
                            position: "left",
                            title: {
                                display: true,
                                text: "Gallons",
                                color: "#111827",
                                font: {
                                    weight: "bold"
                                }
                            },
                            ticks: {
                                color: "#111827",
                                callback: value => Number(value).toLocaleString()
                            },
                            grid: {
                                color: "rgba(0,0,0,0.08)"
                            }
                        },
                        y1: {
                            beginAtZero: true,
                            position: "right",
                            title: {
                                display: true,
                                text: "Loss %",
                                color: "#991b1b",
                                font: {
                                    weight: "bold"
                                }
                            },
                            ticks: {
                                color: "#991b1b",
                                callback: value => Number(value).toFixed(0) + "%"
                            },
                            grid: {
                                drawOnChartArea: false
                            }
                        }
                    }
                }
            });
        }

                async function deleteConsumptionReport(id) {
            if (!id) {
                alert("Missing report ID.");
                return;
            }

            const confirmed = confirm("Delete this saved consumption report? This cannot be undone.");

            if (!confirmed) {
                return;
            }

            const response = await fetch(`/api/scada/consumption-report/${id}`, {
                method: "DELETE"
            });

            if (!response.ok) {
                const errorText = await response.text();
                alert("Delete failed:\n" + errorText);
                return;
            }

            await loadConsumptionHistory();
        }

