<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
        setDefaultDates();

        function setDefaultDates() {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);

            document.getElementById("siteStartDate").valueAsDate = firstDay;
            document.getElementById("siteEndDate").valueAsDate = today;
            document.getElementById("meterStartDate").valueAsDate = firstDay;
            document.getElementById("meterEndDate").valueAsDate = today;
            document.getElementById("consumptionLastReadDate").valueAsDate = firstDay;
            document.getElementById("consumptionCurrentReadDate").valueAsDate = today;
            document.getElementById("pumpStartDate").valueAsDate = firstDay;
            document.getElementById("pumpEndDate").valueAsDate = today;
            document.getElementById("ncMorStartDate").valueAsDate = firstDay;
            document.getElementById("ncMorEndDate").valueAsDate = today;
        }

        async function loadSiteReport() {
            const site = document.getElementById("siteSelect").value;
            const startDate = document.getElementById("siteStartDate").value;
            const endDate = document.getElementById("siteEndDate").value;

            if (!startDate || !endDate) {
                alert("Please select a beginning and ending date.");
                return;
            }

            const response = await fetch(`/api/scada/monthly-site-report?site=${encodeURIComponent(site)}&startDate=${startDate}&endDate=${endDate}`);

            if (!response.ok) {
                alert("Error loading monthly report.");
                return;
            }

            const data = await response.json();

            renderSiteRows(data.rows || []);
            renderSummaryRows(data.summary || []);
        }

        function renderSiteRows(rows) {
            const body = document.getElementById("siteReportBody");
            body.innerHTML = "";

            if (rows.length === 0) {
                body.innerHTML = `<tr><td colspan="8">No results found.</td></tr>`;
                return;
            }

            rows.forEach(row => {
                const tr = document.createElement("tr");

                tr.innerHTML = `
                    <td>${formatDateTime(row.date)}</td>
                    <td>${row.site}</td>
                    <td>${row.name}</td>
                    <td>${formatNumber(row.gallonsPumped)}</td>
                    <td>${formatValue(row.chlorine)}</td>
                    <td>${formatValue(row.phosphate)}</td>
                    <td>${formatValue(row.ph)}</td>
                    <td>${formatValue(row.temperature)}</td>
                `;

                body.appendChild(tr);
            });
        }

        function renderSummaryRows(rows) {
            const body = document.getElementById("summaryBody");
            body.innerHTML = "";

            if (rows.length === 0) {
                body.innerHTML = `<tr><td colspan="5">No summary found.</td></tr>`;
                return;
            }

            rows.forEach(row => {
                const tr = document.createElement("tr");

                tr.innerHTML = `
                    <td>${row.site}</td>
                    <td>${row.name}</td>
                    <td>${row.daysPumped}</td>
                    <td>${formatNumber(row.maxGallonsPumped)}</td>
                    <td>${formatNumber(row.totalGallonsPumped)}</td>
                `;

                body.appendChild(tr);
            });
        }

        async function loadMeterTotalReport() {
            const startDate = document.getElementById("meterStartDate").value;
            const endDate = document.getElementById("meterEndDate").value;

            if (!startDate || !endDate) {
                alert("Please select a beginning and ending date.");
                return;
            }

            const response = await fetch(`/api/scada/meter-reading-total-report?startDate=${startDate}&endDate=${endDate}`);

            if (!response.ok) {
                alert("Error loading total meter report.");
                return;
            }

            const data = await response.json();

            document.getElementById("totalGallons").innerText =
                formatNumber(data.totalGallonsPumped);
        }

        async function loadPumpStationReport() {
            const station = document.getElementById("pumpStationSelect").value;
            const startDate = document.getElementById("pumpStartDate").value;
            const endDate = document.getElementById("pumpEndDate").value;

            if (!startDate || !endDate) {
                alert("Please choose a beginning and ending date.");
                return;
            }

            const response = await fetch(`/api/scada/pump-station-report?station=${encodeURIComponent(station)}&startDate=${startDate}&endDate=${endDate}`);

            const body = document.getElementById("pumpStationReportBody");
            body.innerHTML = "";

            if (!response.ok) {
                body.innerHTML = `<tr><td colspan="5">Error loading pump station report.</td></tr>`;
                return;
            }

            const rows = await response.json();

            if (!rows || rows.length === 0) {
                body.innerHTML = `<tr><td colspan="5">No pump station results found.</td></tr>`;
                return;
            }

            rows.forEach(row => {
                const tr = document.createElement("tr");

                tr.innerHTML = `
                    <td>${formatDateTime(row.date)}</td>
                    <td>${row.station}</td>
                    <td>${row.pump}</td>
                    <td>${formatValue(row.reading)}</td>
                    <td>${formatValue(row.hoursRun)}</td>
                `;

                body.appendChild(tr);
            });
        }

        async function generateNcMorScript() {
            const site = document.getElementById("ncMorSite").value;
            const startDate = document.getElementById("ncMorStartDate").value;
            const endDate = document.getElementById("ncMorEndDate").value;

            if (!startDate || !endDate) {
                alert("Please choose beginning and ending dates.");
                return;
            }

            const response = await fetch(`/api/scada/nc-mor-report?site=${encodeURIComponent(site)}&startDate=${startDate}&endDate=${endDate}`);

            if (!response.ok) {
                alert("Error loading NC MOR data.");
                return;
            }

            const data = await response.json();

                    const script =
    `function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function setNcValue(el, value, label) {
        if (!el) {
            console.warn("Missing field:", label);
            return;
        }

        if (value === null || value === undefined || value === "") {
            console.log("Skipping blank value:", label);
            return;
        }

        el.scrollIntoView({ block: "center" });

        if (typeof el.onfocus === "function") {
            el.onfocus();
        }

        el.focus();
        await sleep(200);

        el.value = "";
        await sleep(150);

        el.value = value.toString();

        el.dispatchEvent(new KeyboardEvent("keyup", { bubbles: true }));
        el.dispatchEvent(new Event("input", { bubbles: true }));
        el.dispatchEvent(new Event("change", { bubbles: true }));

        await sleep(200);

        if (typeof el.onblur === "function") {
            el.onblur();
        }

        el.blur();

        await sleep(700);
    }

    function normalizeDateText(value) {
        if (!value) return "";

        const d = new Date(value + "T00:00:00");

        return String(d.getMonth() + 1).padStart(2, "0") + "/" +
            String(d.getDate()).padStart(2, "0") + "/" +
            d.getFullYear();
    }

    function getDistributionRows() {
        return Array.from(document.querySelectorAll("tr[id^='ctl00_head_grdMonthly_ctl']"));
    }

    function findDistributionRowsByDate(dateText) {
        return getDistributionRows().filter(row => row.innerText.includes(dateText));
    }

    function getInputByEndsWith(row, suffix) {
        return Array.from(row.querySelectorAll("input"))
            .find(input => input.id.endsWith(suffix));
    }

    function getChlorineInput(row) {
        return Array.from(row.querySelectorAll("input")).find(input =>
            input.id.toLowerCase().includes("chlorine") ||
            input.id.toLowerCase().includes("freechlorine") ||
            input.id.toLowerCase().includes("txtcl")
        );
    }

    const data = ${JSON.stringify(data, null, 4)};

    (async function () {
        console.log("Waiting for NC MOR page to finish loading...");
        await sleep(2500);

        const isDistribution = data.length > 0 && data[0].code;

        if (isDistribution) {
            const usedRows = new Set();

            for (let index = 0; index < data.length; index++) {
                const item = data[index];
                const dateText = normalizeDateText(item.date);

                const matchingRows = findDistributionRowsByDate(dateText)
                    .filter(row => !usedRows.has(row.id));

                if (matchingRows.length === 0) {
                    console.warn("No unused distribution row found for date:", dateText, item);
                    continue;
                }

                const row = matchingRows[0];
                usedRows.add(row.id);

                const codeInput = getInputByEndsWith(row, "_txtLocationCode");
                const addressInput = getInputByEndsWith(row, "_txtSampleAddress");
                const chlorineInput = getChlorineInput(row);

                console.log("Filling distribution row", row.id, item);

                    await setNcValue(codeInput, item.code, row.id + " Location Code");

                    await sleep(1200);

                    await setNcValue(addressInput, item.location, row.id + " Sample Address");

                    await sleep(1200);

                    await setNcValue(chlorineInput, item.chlorine, row.id + " Chlorine");

                    await sleep(1200);
            }

            console.log("Distribution NC MOR autofill complete. Wait at least 10 seconds, then refresh the NC page to confirm saved values.");
            return;
        }

        for (let index = 0; index < data.length; index++) {
            const row = data[index];

            const rowDate = new Date(row.date + "T00:00:00");
            const rowIndex = (rowDate.getDate() + 1).toString().padStart(2, "0");

            console.log("Filling source water row", rowIndex, row);

            await setNcValue(
                document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtTime\`),
                row.time,
                \`Row \${rowIndex} Time\`
            );

            await setNcValue(
                document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtSourcePumped\`),
                Math.round(row.gallons),
                \`Row \${rowIndex} Source Pumped\`
            );

            await setNcValue(
                document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtTotalChlorine\`),
                row.chlorine,
                \`Row \${rowIndex} Chlorine\`
            );

            await setNcValue(
                document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtMonochloramine\`),
                row.phosphate,
                \`Row \${rowIndex} Phosphate\`
            );

            await sleep(1200);
        }

        console.log("Source Water NC MOR autofill complete. Wait at least 10 seconds, then refresh the NC page to confirm saved values.");
    })();`;

            document.getElementById("ncMorScript").value = script;
        }

        function copyNcMorScript() {
            const box = document.getElementById("ncMorScript");
            box.select();
            document.execCommand("copy");
            alert("NC MOR script copied.");
        }

                let consumptionChart = null;
        let lastConsumptionReport = null;

        async function loadConsumptionReport() {
            const lastReadDate = document.getElementById("consumptionLastReadDate").value;
            const currentReadDate = document.getElementById("consumptionCurrentReadDate").value;
            const consumedGallons = document.getElementById("consumerGallons").value || 0;
            const notes = document.getElementById("consumptionNotes").value || "";

            if (!lastReadDate || !currentReadDate) {
                alert("Please select the last meter read date and current meter read date.");
                return;
            }

            if (Number(consumedGallons) <= 0) {
                alert("Please enter the total consumer gallons from the meter readings.");
                return;
            }

            const url =
                `/api/scada/consumption-report` +
                `?lastReadDate=${encodeURIComponent(lastReadDate)}` +
                `&currentReadDate=${encodeURIComponent(currentReadDate)}` +
                `&consumedGallons=${encodeURIComponent(consumedGallons)}` +
                `&notes=${encodeURIComponent(notes)}`;

            const response = await fetch(url);

            if (!response.ok) {
                alert("Error loading consumption report.");
                return;
            }

            const data = await response.json();
            lastConsumptionReport = data;

            renderConsumptionReport(data);
        }

        function renderConsumptionReport(data) {
            document.getElementById("consumptionPumped").innerText = formatNumber(data.waterPumped);
            document.getElementById("consumptionConsumed").innerText = formatNumber(data.waterConsumed);
            document.getElementById("consumptionLoss").innerText = formatNumber(data.waterLoss);
            document.getElementById("consumptionLossPercent").innerText = formatPercent(data.lossPercent);

            document.getElementById("consumptionBillingDays").innerText = data.billingDays;
            document.getElementById("consumptionPumpedAvg").innerText = formatNumber(data.pumpedAveragePerDay);
            document.getElementById("consumptionConsumedAvg").innerText = formatNumber(data.consumedAveragePerDay);
            document.getElementById("consumptionDateRange").innerText =
                `${formatShortDate(data.lastReadDate)} through ${formatShortDate(data.currentReadDate)}`;

            updateConsumptionWarning(data);
            renderConsumptionChart(data);
        }

        function updateConsumptionWarning(data) {
            const warning = document.getElementById("consumptionWarning");

            warning.className = "consumption-warning consumption-warning-neutral";

            const lossPercent = Number(data.lossPercent || 0);

            if (lossPercent >= 0.30) {
                warning.className = "consumption-warning consumption-warning-alert";
                warning.innerText =
                    `High water loss: ${formatPercent(lossPercent)} unaccounted for. ` +
                    `${formatNumber(data.waterLoss)} gallons were pumped but not billed/consumed. ` +
                    `Review known leaks, flushing, breaks, or meter issues.`;
            } else if (lossPercent >= 0.20) {
                warning.className = "consumption-warning consumption-warning-watch";
                warning.innerText =
                    `Watch: ${formatPercent(lossPercent)} unaccounted for. ` +
                    `${formatNumber(data.waterLoss)} gallons difference between pumped and consumed.`;
            } else {
                warning.className = "consumption-warning consumption-warning-good";
                warning.innerText =
                    `Loss is ${formatPercent(lossPercent)} for this billing period. ` +
                    `Unaccounted-for water: ${formatNumber(data.waterLoss)} gallons.`;
            }
        }

        function renderConsumptionChart(data) {
            const ctx = document.getElementById("consumptionChart");

            if (consumptionChart) {
                consumptionChart.destroy();
            }

            consumptionChart = new Chart(ctx, {
                type: "bar",
                data: {
                    labels: ["Water Pumped", "Water Consumed", "Unaccounted For"],
                    datasets: [{
                        label: "Gallons",
                        data: [
                            data.waterPumped,
                            data.waterConsumed,
                            data.waterLoss
                        ],
                        backgroundColor: [
                            "#2563eb",
                            "#059669",
                            data.lossPercent >= 0.30 ? "#dc2626" : data.lossPercent >= 0.20 ? "#f59e0b" : "#64748b"
                        ],
                        borderColor: [
                            "#1d4ed8",
                            "#047857",
                            data.lossPercent >= 0.30 ? "#991b1b" : data.lossPercent >= 0.20 ? "#b45309" : "#475569"
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return formatNumber(context.raw) + " gallons";
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: "#374151",
                                font: {
                                    weight: "bold"
                                }
                            },
                            grid: {
                                color: "rgba(0,0,0,0.08)"
                            }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: "#374151",
                                callback: function (value) {
                                    return Number(value).toLocaleString();
                                }
                            },
                            grid: {
                                color: "rgba(0,0,0,0.08)"
                            }
                        }
                    }
                }
            });
        }

        function exportConsumptionReport() {
            const lastReadDate = document.getElementById("consumptionLastReadDate").value;
            const currentReadDate = document.getElementById("consumptionCurrentReadDate").value;
            const consumedGallons = document.getElementById("consumerGallons").value || 0;
            const notes = document.getElementById("consumptionNotes").value || "";

            if (!lastReadDate || !currentReadDate) {
                alert("Please select the last meter read date and current meter read date.");
                return;
            }

            if (Number(consumedGallons) <= 0) {
                alert("Please enter the total consumer gallons before exporting.");
                return;
            }

            const url =
                `/api/scada/consumption-report-export` +
                `?lastReadDate=${encodeURIComponent(lastReadDate)}` +
                `&currentReadDate=${encodeURIComponent(currentReadDate)}` +
                `&consumedGallons=${encodeURIComponent(consumedGallons)}` +
                `&notes=${encodeURIComponent(notes)}`;

            window.location.href = url;
        }

        function formatPercent(value) {
            if (value === null || value === undefined || isNaN(value)) {
                return "0.00%";
            }

            return Number(value).toLocaleString(undefined, {
                style: "percent",
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function formatShortDate(value) {
            if (!value) return "";

            return new Date(value).toLocaleDateString(undefined, {
                year: "numeric",
                month: "2-digit",
                day: "2-digit"
            });
        }

        function formatDateTime(value) {
            if (!value) return "";

            return new Date(value).toLocaleString(undefined, {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
                hour: "2-digit",
                minute: "2-digit",
                second: "2-digit",
                hour12: false
            });
        }

        function formatValue(value) {
            if (value === null || value === undefined || value === "") return "";

            return Number(value).toLocaleString(undefined, {
                maximumFractionDigits: 3
            });
        }

        function formatNumber(value) {
            if (value === null || value === undefined || value === "") return "0";

            return Number(value).toLocaleString(undefined, {
                maximumFractionDigits: 0
            });
        }
</script>