@page
@model Well_Readings.Pages.MonthlyReportModel

<h1>Monthly Reports</h1>

<section class="report-card">
    <h2>Site Monthly Report</h2>

    <div class="filter-row">
        <label>Site</label>
        <select id="siteSelect">
            <option>All Sites</option>
            <option>Reeves Well Site</option>
            <option>Park Well Site</option>
            <option>Woods</option>
            <option>Catawissa</option>
            <option>New</option>
            <option>Oakwood</option>
            <option>Ray</option>
            <option>Filter Plant</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="siteStartDate" />

        <label>Ending Date</label>
        <input type="date" id="siteEndDate" />

        <button type="button" onclick="loadSiteReport()">Run Report</button>
    </div>

    <h3>Daily Results</h3>

    <table class="report-table">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Site</th>
                <th>Well / Filter</th>
                <th>Gallons Pumped</th>
                <th>Chlorine</th>
                <th>Phosphate</th>
                <th>pH</th>
                <th>Temperature</th>
            </tr>
        </thead>
        <tbody id="siteReportBody"></tbody>
    </table>

    <h3>Summary</h3>

    <table class="report-table">
        <thead>
            <tr>
                <th>Site</th>
                <th>Well / Filter</th>
                <th>Days Pumped</th>
                <th>Max Gallons Pumped</th>
                <th>Total Gallons Pumped</th>
            </tr>
        </thead>
        <tbody id="summaryBody"></tbody>
    </table>
</section>

<section class="report-card">
    <h2>Meter Reading Report</h2>

    <div class="meter-filter-row">
        <label>Beginning Date</label>
        <input type="date" id="meterStartDate" />

        <label>Ending Date</label>

        <div class="meter-ending-box">
            <input type="date" id="meterEndDate" />
            <div class="meter-warning">DAY AFTER METERS READ</div>
        </div>

        <button type="button" onclick="loadMeterTotalReport()">Run Total Report</button>
    </div>

    <div class="total-box">
        Total Gallons Pumped:
        <span id="totalGallons">0</span>
    </div>
</section>

<section class="report-card consumption-card">
    <h2>Consumption Report</h2>

    <p class="help-text">
        Compare customer meter consumption against total water pumped between meter reading dates.
    </p>

    <div class="filter-row">
        <label>Last Meter Read Date</label>
        <input type="date" id="consumptionLastReadDate" />

        <label>Current Meter Read Date</label>
        <input type="date" id="consumptionCurrentReadDate" />

        <label>Total Consumer Gallons</label>
        <input type="number" id="consumerGallons" placeholder="Example: 5147670" min="0" step="1" />

        <button type="button" onclick="loadConsumptionReport()">Run Consumption Report</button>
        <button type="button" onclick="exportConsumptionReport()">Export Spreadsheet</button>
    </div>

    <label class="notes-label">Notes / Known Issues</label>
    <textarea id="consumptionNotes" class="notes-box" placeholder="Example: Known leak repaired on S. Jefferson Ave., hydrant flushing, main break, etc."></textarea>

    <div id="consumptionWarning" class="consumption-warning consumption-warning-neutral">
        Enter the billing meter read dates and total consumer gallons, then run the report.
    </div>

    <div class="consumption-kpi-grid">
        <div class="consumption-kpi">
            <div class="consumption-kpi-label">Water Pumped</div>
            <div class="consumption-kpi-value" id="consumptionPumped">0</div>
        </div>

        <div class="consumption-kpi">
            <div class="consumption-kpi-label">Water Consumed</div>
            <div class="consumption-kpi-value" id="consumptionConsumed">0</div>
        </div>

        <div class="consumption-kpi">
            <div class="consumption-kpi-label">Unaccounted For</div>
            <div class="consumption-kpi-value" id="consumptionLoss">0</div>
        </div>

        <div class="consumption-kpi">
            <div class="consumption-kpi-label">% Loss</div>
            <div class="consumption-kpi-value" id="consumptionLossPercent">0%</div>
        </div>
    </div>

    <div class="consumption-detail-grid">
        <div>
            <strong>Billing Days:</strong>
            <span id="consumptionBillingDays">0</span>
        </div>

        <div>
            <strong>Pumped Avg/Day:</strong>
            <span id="consumptionPumpedAvg">0</span>
        </div>

        <div>
            <strong>Consumed Avg/Day:</strong>
            <span id="consumptionConsumedAvg">0</span>
        </div>

        <div>
            <strong>Date Range:</strong>
            <span id="consumptionDateRange">-</span>
        </div>
    </div>

    <div class="consumption-chart-wrap">
        <canvas id="consumptionChart"></canvas>
    </div>
</section>

<section class="report-card">
    <h2>Pump Station Report</h2>

<section class="report-card">
    <h2>Pump Station Report</h2>

    <div class="filter-row">
        <label>Pump Station</label>
        <select id="pumpStationSelect">
            <option value="Beaver Creek">Beaver Creek</option>
            <option value="Greenfield">Greenfield</option>
            <option value="Helen Blevins">Helen Blevins</option>
            <option value="Dogget">Dogget</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="pumpStartDate" />

        <label>Ending Date</label>
        <input type="date" id="pumpEndDate" />

        <button type="button" onclick="loadPumpStationReport()">Run Pump Station Report</button>
    </div>

    <table class="report-table">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Station</th>
                <th>Pump</th>
                <th>Reading Entered</th>
                <th>Hours Run</th>
            </tr>
        </thead>
        <tbody id="pumpStationReportBody"></tbody>
    </table>
</section>

<section class="report-card">
    <h2>NC MOR Autofill Report</h2>

    <div class="filter-row">
        <label>Site</label>
        <select id="ncMorSite">
            <option value="Reeves Well Site">Reeves Well Site</option>
            <option value="Park Well Site">Park Well Site</option>
            <option value="Woods">Woods</option>
            <option value="Catawissa">Catawissa</option>
            <option value="New">New</option>
            <option value="Oakwood">Oakwood</option>
            <option value="Ray">Ray</option>
            <option value="Filter Plant">Filter Plant</option>
            <option value="Distribution Points">Distribution Points</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="ncMorStartDate" />

        <label>Ending Date</label>
        <input type="date" id="ncMorEndDate" />

        <button type="button" onclick="generateNcMorScript()">Generate NC MOR Script</button>
        <button type="button" onclick="copyNcMorScript()">Copy Script</button>
    </div>

    <p class="help-text">
        Generate the script, copy it, paste it into the NC MOR console, and wait at least 10 seconds after it finishes.
    </p>

    <textarea id="ncMorScript" class="script-box"></textarea>
</section>

<style>
