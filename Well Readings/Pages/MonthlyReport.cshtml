@page
@model Well_Readings.Pages.MonthlyReportModel

<h1>Monthly Reports</h1>

<section class="report-card">
    <h2>Site Monthly Report</h2>

    <div class="filter-row">
        <label>Site</label>
        <select id="siteSelect">
            <option>All Sites</option>
            <option>Reeves Well Site</option>
            <option>Park Well Site</option>
            <option>Woods</option>
            <option>Catawissa</option>
            <option>New</option>
            <option>Oakwood</option>
            <option>Ray</option>
            <option>Filter Plant</option>
        </select>

        <label>Beginning Date</label>
        <input type="date" id="siteStartDate" />

        <label>Ending Date</label>
        <input type="date" id="siteEndDate" />

        <button type="button" onclick="loadSiteReport()">Run Report</button>
    </div>

    <h3>Daily Results</h3>

    <table class="report-table">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Site</th>
                <th>Well / Filter</th>
                <th>Gallons Pumped</th>
                <th>Chlorine</th>
                <th>Phosphate</th>
                <th>pH</th>
                <th>Temperature</th>
            </tr>
        </thead>
        <tbody id="siteReportBody"></tbody>
    </table>

    <h3>Summary</h3>

    <table class="report-table">
        <thead>
            <tr>
                <th>Site</th>
                <th>Well / Filter</th>
                <th>Days Pumped</th>
                <th>Max Gallons Pumped</th>
            </tr>
        </thead>
        <tbody id="summaryBody"></tbody>
    </table>
</section>

<section class="report-card">
    <h2>Meter Reading Report</h2>

    <div class="filter-row">
        <label>Beginning Date</label>
        <input type="date" id="meterStartDate" />

        <label>Ending Date</label>
        <input type="date" id="meterEndDate" />

        <button type="button" onclick="loadMeterTotalReport()">Run Total Report</button>
    </div>

    <div class="total-box">
        Total Gallons Pumped:
        <span id="totalGallons">0</span>
    </div>
</section>

<hr />

<section class="report-section">
    <h2>Pump Station Report</h2>

    <div class="report-controls">
        <label>Pump Station:</label>
        <select id="pumpStationSelect">
            <option value="Beaver Creek">Beaver Creek</option>
            <option value="Greenfield">Greenfield</option>
            <option value="Helen Blevins">Helen Blevins</option>
            <option value="Dogget">Dogget</option>
        </select>

        <label>Beginning Date:</label>
        <input type="date" id="pumpStartDate" />

        <label>Ending Date:</label>
        <input type="date" id="pumpEndDate" />

        <button type="button" onclick="loadPumpStationReport()">Run Pump Station Report</button>
    </div>

    <table class="report-table">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Station</th>
                <th>Pump</th>
                <th>Reading Entered</th>
                <th>Hours Run</th>
            </tr>
        </thead>
        <tbody id="pumpStationReportBody"></tbody>
    </table>
</section>

<hr />

<section class="report-section">
    <h2>NC MOR Autofill Report</h2>

    <div class="report-controls">
        <label>Site:</label>
        <select id="ncMorSite">
            <option value="Reeves Well Site">Reeves Well Site</option>
            <option value="Park Well Site">Park Well Site</option>
            <option value="Woods">Woods</option>
            <option value="Catawissa">Catawissa</option>
            <option value="New">New</option>
            <option value="Oakwood">Oakwood</option>
            <option value="Ray">Ray</option>
            <option value="Filter Plant">Filter Plant</option>
        </select>

        <label>Beginning Date:</label>
        <input type="date" id="ncMorStartDate" />

        <label>Ending Date:</label>
        <input type="date" id="ncMorEndDate" />

        <button type="button" onclick="generateNcMorScript()">Generate NC MOR Script</button>
    </div>

    <textarea id="ncMorScript" style="width:100%;height:300px;margin-top:15px;"></textarea>

    <button type="button" onclick="copyNcMorScript()">Copy Script</button>
</section>

<style>
    .report-card {
        background: #f3f4f6;
        color: #111827;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 25px;
    }

        .report-card h2,
        .report-card h3,
        .report-card label {
            color: #111827;
        }

    .filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        margin-bottom: 20px;
    }

        .filter-row label {
            font-weight: bold;
        }

        .filter-row input,
        .filter-row select {
            padding: 8px;
            border: 1px solid #374151;
            border-radius: 6px;
            color: #111827;
            background: white;
        }

        .filter-row button {
            padding: 10px 18px;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
        }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        color: #111827;
        margin-bottom: 25px;
    }

        .report-table th,
        .report-table td {
            border: 1px solid #d1d5db;
            padding: 9px;
            text-align: left;
        }

        .report-table th {
            background: #1f2937;
            color: white;
        }

        .report-table tbody tr:nth-child(odd) {
            background: #ffffff;
        }

        .report-table tbody tr:nth-child(even) {
            background: #eff6ff;
        }

    .total-box {
        background: white;
        color: #111827;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 18px;
        font-size: 22px;
        font-weight: bold;
    }

    #totalGallons {
        color: #047857;
    }

    @@media (max-width: 800px) {
        .filter-row {
            display: block;
        }

            .filter-row label,
            .filter-row input,
            .filter-row select,
            .filter-row button {
                display: block;
                width: 100%;
                margin-bottom: 10px;
            }

        .report-table {
            font-size: 13px;
        }
    }
</style>

<script>
    setDefaultDates();

    function setDefaultDates() {
        const today = new Date();
        const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);

        document.getElementById("siteStartDate").valueAsDate = firstDay;
        document.getElementById("siteEndDate").valueAsDate = today;
        document.getElementById("meterStartDate").valueAsDate = firstDay;
        document.getElementById("meterEndDate").valueAsDate = today;
    }

    async function loadSiteReport() {
        const site = document.getElementById("siteSelect").value;
        const startDate = document.getElementById("siteStartDate").value;
        const endDate = document.getElementById("siteEndDate").value;

        if (!startDate || !endDate) {
            alert("Please select a beginning and ending date.");
            return;
        }

        const response = await fetch(`/api/scada/monthly-site-report?site=${encodeURIComponent(site)}&startDate=${startDate}&endDate=${endDate}`);

        if (!response.ok) {
            alert("Error loading monthly report.");
            return;
        }

        const data = await response.json();

        renderSiteRows(data.rows || []);
        renderSummaryRows(data.summary || []);
    }

    function renderSiteRows(rows) {
        const body = document.getElementById("siteReportBody");
        body.innerHTML = "";

        if (rows.length === 0) {
            body.innerHTML = `<tr><td colspan="8">No results found.</td></tr>`;
            return;
        }

        rows.forEach(row => {
            const tr = document.createElement("tr");

            tr.innerHTML = `
                <td>${formatDateTime(row.date)}</td>
                <td>${row.site}</td>
                <td>${row.name}</td>
                <td>${formatNumber(row.gallonsPumped)}</td>
                <td>${formatValue(row.chlorine)}</td>
                <td>${formatValue(row.phosphate)}</td>
                <td>${formatValue(row.ph)}</td>
                <td>${formatValue(row.temperature)}</td>
            `;

            body.appendChild(tr);
        });
    }

    function renderSummaryRows(rows) {
        const body = document.getElementById("summaryBody");
        body.innerHTML = "";

        if (rows.length === 0) {
            body.innerHTML = `<tr><td colspan="4">No summary found.</td></tr>`;
            return;
        }

        rows.forEach(row => {
            const tr = document.createElement("tr");

            tr.innerHTML = `
                <td>${row.site}</td>
                <td>${row.name}</td>
                <td>${row.daysPumped}</td>
                <td>${formatNumber(row.maxGallonsPumped)}</td>
            `;

            body.appendChild(tr);
        });
    }

    async function loadMeterTotalReport() {
        const startDate = document.getElementById("meterStartDate").value;
        const endDate = document.getElementById("meterEndDate").value;

        if (!startDate || !endDate) {
            alert("Please select a beginning and ending date.");
            return;
        }

        const response = await fetch(`/api/scada/meter-reading-total-report?startDate=${startDate}&endDate=${endDate}`);

        if (!response.ok) {
            alert("Error loading total meter report.");
            return;
        }

        const data = await response.json();

        document.getElementById("totalGallons").innerText =
            formatNumber(data.totalGallonsPumped);
    }

    function formatDateTime(value) {
        if (!value) return "";
        return new Date(value).toLocaleString();
    }
    
    function formatDate(value) {
        if (!value) return "";
        return new Date(value).toLocaleDateString();
    }

    function formatValue(value) {
        if (value === null || value === undefined) return "";
        return Number(value).toLocaleString(undefined, {
            maximumFractionDigits: 3
        });
    }

    function formatNumber(value) {
        if (value === null || value === undefined) return "0";
        return Number(value).toLocaleString(undefined, {
            maximumFractionDigits: 0
        });
    }

        async function loadPumpStationReport() {
        const station = document.getElementById("pumpStationSelect").value;
        const startDate = document.getElementById("pumpStartDate").value;
        const endDate = document.getElementById("pumpEndDate").value;

        if (!startDate || !endDate) {
            alert("Please choose a beginning and ending date.");
            return;
        }

        const response = await fetch(`/api/scada/pump-station-report?station=${encodeURIComponent(station)}&startDate=${startDate}&endDate=${endDate}`);

        const body = document.getElementById("pumpStationReportBody");
        body.innerHTML = "";

        if (!response.ok) {
            body.innerHTML = `<tr><td colspan="5">Error loading pump station report.</td></tr>`;
            return;
        }

        const rows = await response.json();

        rows.forEach(row => {
            const tr = document.createElement("tr");

            tr.innerHTML = `
                <td>${new Date(row.date).toLocaleString([], { hour12: false })}</td>
                <td>${row.station}</td>
                <td>${row.pump}</td>
                <td>${row.reading}</td>
                <td>${row.hoursRun}</td>
            `;

            body.appendChild(tr);
        });
    }

        async function generateNcMorScript() {
        const site = document.getElementById("ncMorSite").value;
        const startDate = document.getElementById("ncMorStartDate").value;
        const endDate = document.getElementById("ncMorEndDate").value;

        if (!startDate || !endDate) {
            alert("Please choose beginning and ending dates.");
            return;
        }

        const response = await fetch(`/api/scada/nc-mor-report?site=${encodeURIComponent(site)}&startDate=${startDate}&endDate=${endDate}`);

        if (!response.ok) {
            alert("Error loading NC MOR data.");
            return;
        }

        const data = await response.json();

        const script = `
        async function setNcValue(el, value) {
        if (!el || value === null || value === undefined || value === "") return;

        el.focus();
        el.className = "TextBoxNoBorderEnter";
        el.value = value.toString();

        if (typeof el.onkeyup === "function") {
            el.onkeyup({ target: el });
        }

        if (typeof el.onchange === "function") {
            el.onchange();
        }

        if (typeof el.onblur === "function") {
            el.onblur();
        } else {
            el.dispatchEvent(new Event("blur", { bubbles: true }));
        }

        await new Promise(resolve => setTimeout(resolve, 250));
    }

    const data = ${JSON.stringify(data, null, 4)};

        (async function () {
    for (let index = 0; index < data.length; index++) {
        const row = data[index];
        const rowIndex = (index + 2).toString().padStart(2, "0");

        await setNcValue(document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtTime\`), row.time);
        await setNcValue(document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtSourcePumped\`), Math.round(row.gallons));
        await setNcValue(document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtTotalChlorine\`), row.chlorine);
        await setNcValue(document.getElementById(\`ctl00_head_grdMonthlyData_ctl\${rowIndex}_txtMonochloramine\`), row.phosphate);
        }

    console.log("NC MOR autofill complete. Wait a few seconds, then click the site's Save/Submit button if available.");
    })();
    `;

        document.getElementById("ncMorScript").value = script;
    }

    function copyNcMorScript() {
        const box = document.getElementById("ncMorScript");
        box.select();
        document.execCommand("copy");
        alert("NC MOR script copied.");
    }

</script>