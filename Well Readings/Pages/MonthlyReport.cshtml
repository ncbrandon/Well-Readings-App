@page
@model Well_Readings.Pages.MonthlyReportModel

<h2 class="mb-3">Monthly SCADA Dashboard</h2>

<!-- FILTER BAR -->
<form method="get" class="row g-2 mb-3">

    <div class="col-auto">
        <input type="number" name="year" value="@Model.Year" class="form-control" placeholder="Year" />
    </div>

    <div class="col-auto">
        <input type="number" name="month" value="@Model.Month" class="form-control" placeholder="Month" />
    </div>

    <div class="col-auto">
        <button class="btn btn-primary">Load</button>
    </div>

</form>

@if (Model.Rows == null || !Model.Rows.Any())
{
    <div class="alert alert-warning">
        No data available for selected period.
    </div>
}
else
{
    <!-- KPI ROW -->
    <div class="row mb-3">

        <div class="col-md-4">
            <div class="card text-bg-primary shadow">
                <div class="card-body">
                    <h6>Total Sites</h6>
                    <h3>@Model.AvailableSites.Count</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-success shadow">
                <div class="card-body">
                    <h6>Total Gallons</h6>
                    <h3>
                        @Model.TotalGallonsPerSite.Values.Sum()
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-warning shadow">
                <div class="card-body">
                    <h6>Max Daily Site Output</h6>
                    <h3>
                        @Model.MaxDailyGallonsPerSite.Values.Max()
                    </h3>
                </div>
            </div>
        </div>

    </div>

    <!-- SITE CARDS -->
    <h4>Site Status</h4>

    <div class="row mb-4">

        @foreach (var site in Model.AvailableSites)
        {
            var total = Model.TotalGallonsPerSite[site];

            <div class="col-md-3 mb-3">

                <div class="card shadow border-0
                            @(total > 50000 ? "bg-danger text-white"
                                           : total > 20000 ? "bg-warning"
                                           : "bg-success text-white")">

            <div class="card-body">
                <h6>@site</h6>
                <h4>@total</h4>
                <small>Gallons</small>
            </div>

                </div>

            </div>
        }

    </div>

    <!-- CHART -->
    <div class="card mb-4 shadow">
        <div class="card-body">
            <h5>Production Distribution</h5>
            <canvas id="siteChart"></canvas>
        </div>
    </div>

    <!-- DETAIL TABLE -->
    <div class="card shadow">
        <div class="card-header">
            Well-Level Detail
        </div>

        <div class="card-body p-0">

            <table class="table table-hover mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Well</th>
                        <th>Site</th>
                        <th>Total</th>
                        <th>Avg</th>
                        <th>Days</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var row in Model.Rows)
                    {
                        <tr class="@(row.IsAnomaly ? "table-danger" : "")">

                            <td>@row.WellName</td>
                            <td>@row.Site</td>
                            <td>@row.TotalProduction</td>
                            <td>@row.AverageProduction</td>
                            <td>@row.DaysReported</td>

                            <td>
                                @if (row.IsAnomaly)
                                {
                                    <span class="badge bg-danger">ALERT</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">OK</span>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

    <!-- CHART SCRIPT -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const ctx = document.getElementById('siteChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.AvailableSites)),
                datasets: [{
                    label: 'Gallons by Site',
                    data: @Html.Raw(Json.Serialize(
                                            Model.AvailableSites.Select(s => Model.TotalGallonsPerSite[s])
                                    )),
                backgroundColor: 'rgba(54, 162, 235, 0.6)'
            }]
        }
    });
</script>
}
