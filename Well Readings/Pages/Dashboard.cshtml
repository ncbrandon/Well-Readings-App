@page
@model Well_Readings.Pages.ScadaModel

@{
    Layout = "_Layout";
}

<h2>SCADA Dashboard (Live)</h2>

<!-- Everything is now JavaScript-driven -->
<div id="app">
    <div class="kpi-bar">
        <div class="kpi">
            <div>Active Wells</div>
            <h3 id="kpiWells">0</h3>
        </div>

        <div class="kpi">
            <div>Total Flow</div>
            <h3 id="kpiFlow">0</h3>
        </div>

        <div class="kpi">
            <div>Alarms</div>
            <h3 id="kpiAlarms">0</h3>
        </div>
    </div>

    <div id="wellGrid" class="grid"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/scada")
        .build();

    connection.on("scadaUpdate", data => {
        renderSCADA(data);
    });

    connection.start();

    function renderSCADA(data) {
        const grid = document.getElementById("wellGrid");
        grid.innerHTML = "";

        data.forEach(w => {
            const card = document.createElement("div");

            card.className = "card";
            if (w.isAlarm) card.classList.add("alarm");

            card.innerHTML = `
                <h4>${w.wellName}</h4>
                <div>Reading: ${w.lastReading}</div>
                <button onclick="openAlarm('${w.wellName}')">
                    Set Alarm
                </button>
            `;

            grid.appendChild(card);
        });
    }

    function openAlarm(wellName) {
        const high = prompt("High limit:");
        const low = prompt("Low limit:");

        fetch('/api/alarms', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({
                wellId: wellName,
                highLimit: parseFloat(high),
                lowLimit: parseFloat(low),
                enabled: true
            })
        });
    }
</script>


<style>
    body {
        background: #0b1220;
        color: white;
    }

    .kpi-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .kpi {
        background: #111827;
        padding: 10px;
        flex: 1;
        border-radius: 8px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 10px;
    }

    .card {
        background: #111827;
        padding: 10px;
        border-radius: 8px;
        border-left: 4px solid #22c55e;
    }
</style>
