@page
@model Well_Readings.Pages.ScadaModel

<h1 class="title">SCADA Control Room</h1>

<div class="kpi-row">
    <div class="kpi">
        <div class="kpi-label">Wells</div>
        <div class="kpi-value" id="wellCount">0</div>
    </div>

    <div class="kpi">
        <div class="kpi-label">Total Flow</div>
        <div class="kpi-value" id="totalFlow">0</div>
    </div>

    <div class="kpi">
        <div class="kpi-label">Active Alarms</div>
        <div class="kpi-value" id="alarmCount">0</div>
    </div>
    <div class="kpi">
        <div class="kpi-label">Plant Flow</div>
        <div class="kpi-value" id="plantFlow">0</div>
    </div>

    <div class="kpi">
        <div class="kpi-label">Plant pH</div>
        <div class="kpi-value" id="plantPh">0</div>
    </div>

</div>

<div class="panel">
    <h3>Playback Control</h3>

    <button onclick="toggleMode()">Toggle Live / Playback</button>

    <input type="range" id="timeline" min="0" max="100" value="0" />

    <button onclick="play()">▶ Play</button>
    <button onclick="pause()">⏸ Pause</button>

    <span id="timeLabel"></span>
</div>

<div class="panel">
    <h3>Well Status</h3>
    <div class="well-grid" id="wellGrid"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    let liveMode = true;
    let historyData = [];
    let currentIndex = 0;
    let playing = false;
    let timer = null;

    /* =========================
       LIVE MODE
    ========================= */

    async function loadScada() {
        const res = await fetch('/api/scada/dashboard');
        const data = await res.json();

        const wells = data.wells || [];

        // KPI VALUES
        document.getElementById('wellCount').innerText = wells.length;

        document.getElementById('totalFlow').innerText =
            wells.reduce((sum, x) => sum + (x.totalGallons || 0), 0);

        document.getElementById('alarmCount').innerText =
            wells.filter(x => x.isAlarm).length;

        // PLANT TILE
        const plant = data.plant || {};

        document.getElementById('plantFlow').innerText = plant.flowRate ?? 0;
        document.getElementById('plantPh').innerText = plant.ph ?? 0;

        // GRID
        const grid = document.getElementById('wellGrid');
        grid.innerHTML = '';

        wells.forEach(well => {
            const div = document.createElement('div');
            div.className = 'well-card ' + (well.isAlarm ? 'alert' : '');

            div.innerHTML = `
                <div class="well-name">${well.wellName}</div>

                <div class="well-stat">
                    <span>Last</span>
                    <span>${well.lastReading}</span>
                </div>

                <div class="well-stat">
                    <span>Total</span>
                    <span>${well.totalGallons}</span>
                </div>
            `;

            grid.appendChild(div);
        });
    }



    /* =========================
       PLAYBACK MODE
    ========================= */

    async function loadHistory() {
        const res = await fetch('/api/scada/history?days=7');
        historyData = await res.json();

        buildTimeline();
    }

    function buildTimeline() {
        const slider = document.getElementById('timeline');

        if (!historyData.length) return;

        const maxPoints = Math.max(...historyData.map(w => w.points.length));

        slider.max = maxPoints - 1;
        slider.value = 0;

        slider.oninput = () => {
            currentIndex = parseInt(slider.value);
            renderPlayback();
        };
    }

    function renderPlayback() {
        const grid = document.getElementById('wellGrid');
        grid.innerHTML = '';

        historyData.forEach(well => {
            const point = well.points[currentIndex] || { value: 0, time: '' };

            const trendBars = well.points
                .slice(Math.max(0, currentIndex - 10), currentIndex)
                .map(p => `<div class="mini-bar" style="height:${p.value / 10}px"></div>`)
                .join('');

            const div = document.createElement('div');
            div.className = 'well-card';

            div.innerHTML = `
                <div class="well-name">${well.wellName}</div>

                <div class="mini-chart">${trendBars}</div>

                <div class="well-stat">
                    <span>Value</span>
                    <span>${point.value}</span>
                </div>
            `;

            grid.appendChild(div);

            document.getElementById('timeLabel').innerText = point.time;
        });
    }

    /* =========================
       PLAYBACK CONTROLS
    ========================= */

    function play() {
        if (playing) return;

        playing = true;

        timer = setInterval(() => {
            currentIndex++;

            const slider = document.getElementById('timeline');

            if (currentIndex >= slider.max) {
                currentIndex = 0;
            }

            slider.value = currentIndex;
            renderPlayback();

        }, 500);
    }

    function pause() {
        playing = false;
        clearInterval(timer);
    }

    /* =========================
       MODE SWITCH
    ========================= */

    function toggleMode() {
        liveMode = !liveMode;

        if (liveMode) {
            pause();
            loadScada();
        } else {
            loadHistory();
        }
    }

    /* =========================
       SIGNALR
    ========================= */

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/scadaHub")
        .build();

    connection.on("scadaUpdate", () => {
        if (liveMode) loadScada();
    });

    connection.on("scadaAlarm", alarm => {
        alert(`🚨 ALARM: ${alarm.message}`);
    });

    connection.start();

    /* =========================
       ACTIONS
    ========================= */

    async function ack(wellId) {
        await fetch(`/api/scada/ack/${wellId}`, { method: 'POST' });
    }

    async function setThreshold(wellId, value) {
        await fetch(`/api/scada/threshold/${wellId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: value
        });
    }

    /* INIT */
    loadScada();

</script>
