@page
@model Well_Readings.Pages.ScadaModel

<div class="kpi-row">
    <div class="kpi">
        <div class="kpi-label">Wells</div>
        <div class="kpi-value" id="wellCount">0</div>
    </div>

    <div class="kpi">
        <div class="kpi-label">Pumped Yesterday</div>
        <div class="kpi-value" id="pumpedYesterday">0</div>
    </div>

    <div class="kpi">
        <div class="kpi-label">Pumped Today</div>
        <div class="kpi-value" id="pumpedToday">0</div>
    </div>

    <div class="kpi kpi-clickable" id="pumpedHistoryTile" onclick="togglePumpedHistory()">
        <div class="kpi-label">Pumped History</div>
        <div class="kpi-value">View</div>
    </div>
</div>

<div class="quick-actions">
    <a href="/ScadaEntry" class="quick-card">
        <div class="quick-icon">📝</div>
        <div>
            <strong>Enter Readings</strong>
            <span>Record wells, filters, plant readings, pump stations, and Mt. Jefferson.</span>
        </div>
    </a>

    <a href="/DailyEntry" class="quick-card">
        <div class="quick-icon">📋</div>
        <div>
            <strong>Entry Log</strong>
            <span>View, edit, or delete saved daily entries.</span>
        </div>
    </a>

    <a href="/Maintenance" class="quick-card">
        <div class="quick-icon">🛠️</div>
        <div>
            <strong>Maintenance</strong>
            <span>Mark running sites, track supplies, and save pump install dates.</span>
        </div>
    </a>

    <a href="/MonthlyReport" class="quick-card">
        <div class="quick-icon">📊</div>
        <div>
            <strong>Reports</strong>
            <span>Run monthly, meter, and consumption reports.</span>
        </div>
    </a>
</div>

<div id="pumpedHistoryPanel" class="pumped-history-panel" style="display:none;">
    <div class="pumped-history-header">
        <div>
            <h3>Pumped History</h3>
            <p>Use this to quickly compare recent pumping totals and spot unusually high usage.</p>
        </div>

        <button type="button" class="close-history-btn" onclick="togglePumpedHistory(false)">×</button>
    </div>

    <div class="history-button-row">
        <button type="button" class="history-mode-btn active" id="btn30Days" onclick="loadPumpedHistory('30days')">
            Previous 30 Days
        </button>

        <button type="button" class="history-mode-btn" id="btnYearsToday" onclick="loadPumpedHistory('yearsToday')">
            Previous Years Today
        </button>

        <button type="button" class="history-mode-btn" id="btnSameWeekday" onclick="loadPumpedHistory('sameWeekday')">
            Same Weekday
        </button>
    </div>

    <div id="pumpedHistoryStatus" class="history-status">
        Select an option to load pumped history.
    </div>

    <div id="pumpedHistoryWarning" class="history-warning history-warning-neutral">
        Load pumped history to compare today's pumping against normal usage.
    </div>

    <div class="history-summary-row">
        <div class="history-summary-card">
            <div class="history-summary-label">Records</div>
            <div class="history-summary-value" id="historyRecordCount">-</div>
        </div>

        <div class="history-summary-card">
            <div class="history-summary-label" id="historyAverageLabel">Comparison Avg.</div>
            <div class="history-summary-value" id="historyAverage">-</div>
        </div>

        <div class="history-summary-card">
            <div class="history-summary-label">Today</div>
            <div class="history-summary-value" id="historyToday">-</div>
        </div>

        <div class="history-summary-card">
            <div class="history-summary-label">Difference</div>
            <div class="history-summary-value" id="historyDifference">-</div>
        </div>
    </div>

    <div class="history-chart-wrap">
        <canvas id="pumpedHistoryChart"></canvas>
    </div>

    <div class="history-table-wrap">
        <table class="history-table">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Date</th>
                    <th>Gallons Pumped</th>
                </tr>
            </thead>
            <tbody id="pumpedHistoryTableBody">
            </tbody>
        </table>
    </div>
</div>

<div class="panel">
    <h3>Well Status</h3>
    <div class="well-grid" id="wellGrid"></div>
</div>

<div class="panel">
    <h3>Pump Stations</h3>
    <div class="well-grid" id="pumpGrid"></div>
</div>

<style>
    .flash-red {
        animation: flashRed 1s infinite;
    }

    @@keyframes flashRed {
        0% {
            background-color: #7f1d1d;
        }

        50% {
            background-color: #dc2626;
        }

        100% {
            background-color: #7f1d1d;
        }
    }

    .kpi-clickable {
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

        .kpi-clickable:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.18);
        }

    .pumped-history-panel {
        margin-bottom: 1rem;
        padding: 1.25rem;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
        border: 1px solid #d8dee9;
    }

    .pumped-history-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

        .pumped-history-header h3 {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 800;
            color: #111827;
        }

        .pumped-history-header p {
            margin: 0.25rem 0 0;
            color: #374151;
            font-weight: 500;
        }

    .close-history-btn {
        border: none;
        background: transparent;
        font-size: 2rem;
        line-height: 1;
        cursor: pointer;
        color: #111827;
        font-weight: 700;
    }

    .history-button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .history-mode-btn {
        border: 1px solid #b8c2cf;
        background: #f8fafc;
        color: #111827;
        padding: 0.6rem 1rem;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 700;
    }

        .history-mode-btn.active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

    .history-status {
        margin-bottom: 0.75rem;
        color: #374151;
        font-weight: 700;
    }

    .history-warning {
        margin-bottom: 1rem;
        padding: 0.85rem 1rem;
        border-radius: 14px;
        font-weight: 800;
        line-height: 1.35;
        border: 1px solid transparent;
    }

    .history-warning-neutral {
        background: #f3f4f6;
        color: #1f2937;
        border-color: #d1d5db;
    }

    .history-warning-good {
        background: #ecfdf5;
        color: #065f46;
        border-color: #a7f3d0;
    }

    .history-warning-watch {
        background: #fffbeb;
        color: #92400e;
        border-color: #fcd34d;
    }

    .history-warning-alert {
        background: #fef2f2;
        color: #991b1b;
        border-color: #fca5a5;
    }

    .history-summary-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .history-summary-card {
        background: #f3f4f6;
        border: 1px solid #d1d5db;
        border-radius: 14px;
        padding: 0.85rem;
    }

    .history-summary-label {
        color: #374151;
        font-size: 0.85rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .history-summary-value {
        font-size: 1.25rem;
        font-weight: 900;
        color: #111827;
    }

    .history-chart-wrap {
        height: 340px;
        margin-bottom: 1.25rem;
    }

    .history-table-wrap {
        max-height: 420px;
        overflow: auto;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        background: white;
    }

    .history-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

        .history-table th,
        .history-table td {
            padding: 0.65rem 0.75rem;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        .history-table th {
            background: #f3f4f6;
            position: sticky;
            top: 0;
            z-index: 1;
            color: #374151;
            font-weight: 900;
        }

        .history-table td {
            color: #111827;
            font-weight: 600;
        }

            .history-table td:last-child,
            .history-table th:last-child {
                text-align: right;
            }

    .today-row {
        background: #eff6ff;
        font-weight: 900;
    }

    .high-pumped-row {
        background: #fff7ed;
        font-weight: 900;
    }

    .very-high-pumped-row {
        background: #fef2f2;
        font-weight: 900;
    }

    @@media (max-width: 900px) {
        .history-summary-row {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 600px) {
        .history-summary-row {
            grid-template-columns: 1fr;
        }

        .pumped-history-header {
            align-items: center;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let pumpedHistoryChart = null;

    async function loadScada() {
        const res = await fetch('/api/scada/dashboard');
        const data = await res.json();

        const wells = data.wells || [];

        document.getElementById('wellCount').innerText = wells.length;
        document.getElementById('pumpedYesterday').innerText = formatGallons(data.pumpedYesterday ?? 0);
        document.getElementById('pumpedToday').innerText = formatGallons(data.pumpedToday ?? 0);

        const grid = document.getElementById('wellGrid');
        grid.innerHTML = '';

        wells.forEach(well => {
            const div = document.createElement('div');
            div.className = 'well-card ' + (well.isAlarm ? 'alert' : '');

            div.innerHTML = `
                <div class="well-name">${well.wellName}</div>

                <div class="well-stat">
                    <span>Gallons Yesterday</span>
                    <span>${formatGallons(well.gallonsYesterday)}</span>
                </div>

                <div class="well-stat">
                    <span>Gallons Today</span>
                    <span>${formatGallons(well.gallonsToday)}</span>
                </div>
            `;

            grid.appendChild(div);
        });

        const pumps = data.pumpStations || [];
        const pumpGrid = document.getElementById('pumpGrid');
        pumpGrid.innerHTML = '';

        pumps.forEach(pump => {
            const div = document.createElement('div');
            div.className = 'well-card ' + (pump.flashRed ? 'flash-red' : '');

            div.innerHTML = `
                <div class="well-name">${pump.name}</div>

                <div class="well-stat">
                    <span>Hours Yesterday</span>
                    <span>${pump.hoursYesterday}</span>
                </div>

                <div class="well-stat">
                    <span>Hours Today</span>
                    <span>${pump.hoursToday}</span>
                </div>
            `;

            pumpGrid.appendChild(div);
        });
    }

    function togglePumpedHistory(forceShow) {
        const panel = document.getElementById("pumpedHistoryPanel");

        const shouldShow = forceShow !== undefined
            ? forceShow
            : panel.style.display === "none";

        panel.style.display = shouldShow ? "block" : "none";

        if (shouldShow) {
            loadPumpedHistory("30days");
        }
    }

    async function loadPumpedHistory(mode) {
        const status = document.getElementById("pumpedHistoryStatus");
        const tableBody = document.getElementById("pumpedHistoryTableBody");

        const btn30 = document.getElementById("btn30Days");
        const btnYears = document.getElementById("btnYearsToday");
        const btnSameWeekday = document.getElementById("btnSameWeekday");

        btn30.classList.toggle("active", mode === "30days");
        btnYears.classList.toggle("active", mode === "yearsToday");
        btnSameWeekday.classList.toggle("active", mode === "sameWeekday");

        status.textContent = "Loading pumped history...";
        tableBody.innerHTML = "";

        updateHistorySummary([], mode);
        updateHistoryWarning([], mode);

        try {
            const response = await fetch(`/Scada?handler=PumpedHistory&mode=${encodeURIComponent(mode)}`);

            if (!response.ok) {
                throw new Error("Request failed");
            }

            const data = await response.json();

            if (!data || data.length === 0) {
                status.textContent = "No pumped history found.";
                renderPumpedHistoryChart([], mode);
                updateHistoryWarning([], mode);
                return;
            }

            if (mode === "30days") {
                status.textContent = "Showing the previous 30 days plus today.";
              } else if (mode === "sameWeekday") {
                status.textContent = "Showing the previous 30 matching weekdays plus today.";
              } else {
                status.textContent = "Showing this same calendar date in previous years plus today.";
            }

            const comparison = getComparisonStats(data);

            for (const row of data) {
                const gallons = Number(row.gallonsPumped || 0);
                const tr = document.createElement("tr");

                if (row.isToday) {
                    tr.classList.add("today-row");
                } else if (comparison.average > 0 && gallons >= comparison.average * 1.25) {
                    tr.classList.add("very-high-pumped-row");
                } else if (comparison.average > 0 && gallons >= comparison.average * 1.10) {
                    tr.classList.add("high-pumped-row");
                }

                tr.innerHTML = `
                    <td>${row.dayName ?? ""}</td>
                    <td>${row.displayDate ?? ""}${row.isToday ? " <strong>(Today)</strong>" : ""}</td>
                    <td>${formatGallons(gallons)}</td>
                `;

                tableBody.appendChild(tr);
            }

            updateHistorySummary(data, mode);
            updateHistoryWarning(data, mode);
            renderPumpedHistoryChart(data, mode);
        } catch (error) {
            console.error(error);
            status.textContent = "Could not load pumped history.";
            renderPumpedHistoryChart([], mode);
            updateHistoryWarning([], mode);
        }
    }

    function getComparisonStats(data) {
        if (!data || data.length === 0) {
            return {
                todayRow: null,
                comparisonRows: [],
                average: 0,
                todayValue: 0,
                difference: 0,
                percentDifference: 0
            };
        }

        const todayRow = data.find(x => x.isToday) ?? data[data.length - 1];

        const comparisonRows = data.filter(x => x !== todayRow && !x.isToday);
        const comparisonValues = comparisonRows.map(x => Number(x.gallonsPumped || 0));

        const average = comparisonValues.length > 0
            ? comparisonValues.reduce((a, b) => a + b, 0) / comparisonValues.length
            : 0;

        const todayValue = Number(todayRow?.gallonsPumped || 0);
        const difference = todayValue - average;

        const percentDifference = average > 0
            ? (difference / average) * 100
            : 0;

        return {
            todayRow,
            comparisonRows,
            average,
            todayValue,
            difference,
            percentDifference
        };
    }

    function updateHistoryWarning(data, mode) {
        const warning = document.getElementById("pumpedHistoryWarning");

        warning.className = "history-warning history-warning-neutral";

        if (!data || data.length === 0) {
            warning.textContent = "Load pumped history to compare today's pumping against normal usage.";
            return;
        }

        const stats = getComparisonStats(data);

        if (!stats.todayRow) {
            warning.textContent = "Today's pumped total was not found in this dataset.";
            return;
        }

        if (stats.average <= 0) {
            warning.textContent = "Not enough comparison data to determine whether today is unusually high.";
            return;
        }

        const percent = Math.round(stats.percentDifference);
        const todayText = formatGallons(stats.todayValue);
        const avgText = formatGallons(stats.average);

        let comparisonText = "previous 30-day average";

        if (mode === "yearsToday") {
        comparisonText = "same-date previous-years average";
        } else if (mode === "sameWeekday") {
        comparisonText = "same-weekday average";
        }

        if (percent >= 25) {
            warning.className = "history-warning history-warning-alert";
            warning.textContent = `Warning: Today is ${percent}% higher than the ${comparisonText}. Today: ${todayText} gallons. Average: ${avgText} gallons. This could signal unusually high usage or a possible leak.`;
        } else if (percent >= 10) {
            warning.className = "history-warning history-warning-watch";
            warning.textContent = `Watch: Today is ${percent}% higher than the ${comparisonText}. Today: ${todayText} gallons. Average: ${avgText} gallons.`;
        } else if (percent <= -10) {
            warning.className = "history-warning history-warning-good";
            warning.textContent = `Today is ${Math.abs(percent)}% lower than the ${comparisonText}. Today: ${todayText} gallons. Average: ${avgText} gallons.`;
        } else {
            warning.className = "history-warning history-warning-good";
            warning.textContent = `Today is close to normal compared with the ${comparisonText}. Today: ${todayText} gallons. Average: ${avgText} gallons.`;
        }
    }

    function renderPumpedHistoryChart(data, mode) {
        const ctx = document.getElementById("pumpedHistoryChart");

        if (pumpedHistoryChart) {
            pumpedHistoryChart.destroy();
        }

        const stats = getComparisonStats(data);

        const backgroundColors = data.map(row => {
            const gallons = Number(row.gallonsPumped || 0);

            if (row.isToday) {
                return "#2563eb";
            }

            if (stats.average > 0 && gallons >= stats.average * 1.25) {
                return "#ef4444";
            }

            if (stats.average > 0 && gallons >= stats.average * 1.10) {
                return "#f59e0b";
            }

            return "#76acd2";
        });

        const borderColors = data.map(row => {
            const gallons = Number(row.gallonsPumped || 0);

            if (row.isToday) {
                return "#1d4ed8";
            }

            if (stats.average > 0 && gallons >= stats.average * 1.25) {
                return "#b91c1c";
            }

            if (stats.average > 0 && gallons >= stats.average * 1.10) {
                return "#b45309";
            }

            return "#5a94bd";
        });

        pumpedHistoryChart = new Chart(ctx, {
            type: "bar",
            data: {
                labels: data.map(x => x.isToday ? `${x.displayDate} Today` : x.displayDate),
                datasets: [{
                    label: "Gallons Pumped",
                    data: data.map(x => x.gallonsPumped),
                    backgroundColor: backgroundColors,
                    borderColor: borderColors,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return formatGallons(context.raw) + " gallons";
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: {
                            color: "#374151",
                            maxRotation: 45,
                            minRotation: 45
                        },
                        grid: {
                            color: "rgba(0,0,0,0.08)"
                        }
                    },
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: "#374151",
                            callback: function (value) {
                                return Number(value).toLocaleString();
                            }
                        },
                        grid: {
                            color: "rgba(0,0,0,0.08)"
                        }
                    }
                }
            }
        });
    }

    function updateHistorySummary(data, mode) {
        const recordCount = document.getElementById("historyRecordCount");
        const averageLabel = document.getElementById("historyAverageLabel");
        const average = document.getElementById("historyAverage");
        const today = document.getElementById("historyToday");
        const difference = document.getElementById("historyDifference");

        if (mode === "yearsToday") {
            averageLabel.textContent = "Prior Years Avg.";
        } else if (mode === "sameWeekday") {
            averageLabel.textContent = "Same Weekday Avg.";
        } else {
            averageLabel.textContent = "Prior 30 Days Avg.";
        }

        if (!data || data.length === 0) {
            recordCount.textContent = "-";
            average.textContent = "-";
            today.textContent = "-";
            difference.textContent = "-";
            return;
        }

        const stats = getComparisonStats(data);

        recordCount.textContent = data.length.toLocaleString();
        average.textContent = formatGallons(stats.average);
        today.textContent = formatGallons(stats.todayValue);

        const roundedDifference = Math.round(stats.difference);
        const sign = roundedDifference > 0 ? "+" : "";

        difference.textContent = `${sign}${roundedDifference.toLocaleString()}`;
    }

    function formatGallons(value) {
        if (value === null || value === undefined || isNaN(value)) {
            return "0";
        }

        return Math.round(Number(value)).toLocaleString();
    }

    loadScada();
    setInterval(loadScada, 60000);
</script>