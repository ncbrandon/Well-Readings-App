@page
@model Well_Readings.Pages.ScadaEntryModel

<h1>Daily SCADA Entry</h1>

<div class="entry-header">
    <label>Entry Date:</label>
    <input type="date" id="entryDate" onchange="handleDateChange()" />
    <button type="button" class="load-btn" onclick="handleDateChange()">Load Date</button>
</div>

<div id="draftNotice" class="draft-notice" style="display:none;">
    Draft restored from this device.
</div>

<div id="lockedNotice" class="locked-notice" style="display:none;">
    This date already has saved readings. Submitting again will overwrite that date.
</div>

<div id="siteTiles" class="site-grid"></div>

<div id="entryPanel" class="entry-panel" style="display:none;"></div>

<button type="button" class="submit-btn" onclick="submitReadings()">Submit / Update Readings</button>

<div id="message"></div>

<style>
    .entry-header {
        margin-bottom: 16px;
        color: #111827;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .entry-header label {
        font-weight: bold;
    }

    .entry-header input {
        padding: 8px;
        border: 1px solid #374151;
        border-radius: 6px;
    }

    .load-btn {
        padding: 8px 14px;
        background: #374151;
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: bold;
        cursor: pointer;
    }

    .locked-notice {
        background: #fef3c7;
        color: #92400e;
        padding: 12px;
        border: 1px solid #f59e0b;
        border-radius: 8px;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .draft-notice {
        background: #dbeafe;
        color: #1e3a8a;
        padding: 12px;
        border: 1px solid #60a5fa;
        border-radius: 8px;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .site-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
        margin-bottom: 25px;
    }

    .site-tile {
        background: #1f2937;
        color: white;
        padding: 18px;
        border-radius: 10px;
        cursor: pointer;
        text-align: center;
        font-size: 17px;
        font-weight: bold;
    }

    .site-tile:hover {
        background: #2563eb;
    }

    .site-tile.complete {
        background: #2563eb;
    }

    .site-tile.running {
        background: #047857;
    }

    .entry-panel {
        background: #f3f4f6;
        color: #111827;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 25px;
    }

    .entry-panel h2,
    .entry-panel h3,
    .entry-panel label {
        color: #111827;
    }

    .entry-group {
        background: white;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        margin-bottom: 15px;
        overflow: hidden;
    }

    .group-header {
        background: #e5e7eb;
        color: #111827;
        padding: 12px 15px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        border-bottom: 2px solid #047857;
    }

    .group-body {
        padding: 15px;
    }

    .group-body.collapsed {
        display: none;
    }

    .field-row {
        margin-bottom: 12px;
    }

    .field-row label {
        display: inline-block;
        width: 260px;
        font-weight: bold;
    }

    .field-row input {
        padding: 8px;
        width: 160px;
        color: #111827;
        background-color: #ffffff;
        border: 1px solid #374151;
        border-radius: 5px;
    }

    .submit-btn {
        padding: 12px 24px;
        font-size: 16px;
        font-weight: bold;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
    }

    #message {
        margin-top: 20px;
        font-weight: bold;
        color: #111827;
    }

    @@media (max-width: 700px) {
        .site-grid {
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        .site-tile {
            padding: 12px 6px;
            font-size: 13px;
            min-height: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .field-row label {
            display: block;
            width: auto;
            margin-bottom: 4px;
        }

        .field-row input {
            width: 100%;
            max-width: 260px;
            font-size: 18px;
        }
    }
</style>

<script>
    const sites = [
        {
            name: "Reeves Well Site",
            displayName: "Reeves",
            fields: [
                { label: "Reeves Well Meter", location: "Reeves Well", metricType: "Meter Reading", sourceColumn: "Reeves Well" },
                { label: "Reeves Well A Meter", location: "Reeves Well A", metricType: "Meter Reading", sourceColumn: "Reeves Well A" },
                { label: "Chlorine", location: "Reeves Well Site", metricType: "Chlorine", sourceColumn: "Cl-R" },
                { label: "Phosphate", location: "Reeves Well Site", metricType: "Phosphate", sourceColumn: "PO4-R" },
                { label: "pH", location: "Reeves Well Site", metricType: "pH", sourceColumn: "pH-R" }
            ]
        },
        {
            name: "Park Well Site",
            displayName: "Park",
            fields: [
                { label: "Park Well Meter", location: "Park Well", metricType: "Meter Reading", sourceColumn: "Park Well" },
                { label: "Park Well A Meter", location: "Park Well A", metricType: "Meter Reading", sourceColumn: "Park Well A" },
                { label: "Park Well B Meter", location: "Park Well B", metricType: "Meter Reading", sourceColumn: "Park Well B" },
                { label: "Chlorine", location: "Park Well Site", metricType: "Chlorine", sourceColumn: "Cl-P" },
                { label: "Phosphate", location: "Park Well Site", metricType: "Phosphate", sourceColumn: "PO4-P" },
                { label: "pH", location: "Park Well Site", metricType: "pH", sourceColumn: "pH-P" }
            ]
        },
        {
            name: "Woods",
            displayName: "Woods",
            fields: [
                { label: "Meter Reading", location: "Woods", metricType: "Meter Reading", sourceColumn: "Woods" },
                { label: "Chlorine", location: "Woods", metricType: "Chlorine", sourceColumn: "Cl-W" },
                { label: "Phosphate", location: "Woods", metricType: "Phosphate", sourceColumn: "PO4-W" },
                { label: "pH", location: "Woods", metricType: "pH", sourceColumn: "pH-W" }
            ]
        },
        {
            name: "Catawissa",
            displayName: "Catawissa",
            fields: [
                { label: "Meter Reading", location: "Catawissa", metricType: "Meter Reading", sourceColumn: "Catawissa" },
                { label: "Chlorine", location: "Catawissa", metricType: "Chlorine", sourceColumn: "Cl-C" },
                { label: "Phosphate", location: "Catawissa", metricType: "Phosphate", sourceColumn: "PO4-C" },
                { label: "pH", location: "Catawissa", metricType: "pH", sourceColumn: "pH-C" }
            ]
        },
        {
            name: "New",
            displayName: "New",
            fields: [
                { label: "Meter Reading", location: "New", metricType: "Meter Reading", sourceColumn: "New" },
                { label: "Chlorine", location: "New", metricType: "Chlorine", sourceColumn: "Cl-N" },
                { label: "Phosphate", location: "New", metricType: "Phosphate", sourceColumn: "PO4-N" },
                { label: "pH", location: "New", metricType: "pH", sourceColumn: "pH-N" }
            ]
        },
        {
            name: "Oakwood",
            displayName: "Oakwood",
            fields: [
                { label: "Meter Reading", location: "Oakwood", metricType: "Meter Reading", sourceColumn: "Oakwood" },
                { label: "Chlorine", location: "Oakwood", metricType: "Chlorine", sourceColumn: "Cl-O" },
                { label: "Phosphate", location: "Oakwood", metricType: "Phosphate", sourceColumn: "PO4-O" },
                { label: "pH", location: "Oakwood", metricType: "pH", sourceColumn: "pH-O" }
            ]
        },
        {
            name: "Ray",
            displayName: "Ray",
            fields: [
                { label: "Meter Reading", location: "Ray", metricType: "Meter Reading", sourceColumn: "Ray" },
                { label: "Chlorine", location: "Ray", metricType: "Chlorine", sourceColumn: "Cl-Ray" },
                { label: "Phosphate", location: "Ray", metricType: "Phosphate", sourceColumn: "PO4-Ray" },
                { label: "pH", location: "Ray", metricType: "pH", sourceColumn: "pH-Ray" }
            ]
        },
        {
            name: "Filter Plant",
            displayName: "Filter",
            groups: [
                {
                    title: "Filter 1",
                    fields: [
                        { label: "Feed Pressure", location: "Filter 1", metricType: "Feed Pressure", sourceColumn: "Filter 1 Feed Pressure" },
                        { label: "Feed Flow", location: "Filter 1", metricType: "Feed Flow", sourceColumn: "Filter 1 Feed Flow" },
                        { label: "Filtrate Pressure", location: "Filter 1", metricType: "Filtrate Pressure", sourceColumn: "Filter 1 Filtrate Pressure" },
                        { label: "Filtrate Flow", location: "Filter 1", metricType: "Filtrate Flow", sourceColumn: "Filter 1 Filtrate Flow" },
                        { label: "TMP", location: "Filter 1", metricType: "TMP", sourceColumn: "Filter 1 TMP" },
                        { label: "Total Filter Run Time", location: "Filter 1", metricType: "Total Filter Run Time", sourceColumn: "Filter 1 Total Filter Run Time" },
                        { label: "Total Filtration Flow Yesterday", location: "Filter 1", metricType: "Total Filtration Flow Yesterday", sourceColumn: "Filter 1 Total Filtration Flow Yesterday" },
                        { label: "Pressure Decay", location: "Filter 1", metricType: "Pressure Decay", sourceColumn: "Filter 1 Pressure Decay" }
                    ]
                },
                {
                    title: "Filter 2",
                    fields: [
                        { label: "Feed Pressure", location: "Filter 2", metricType: "Feed Pressure", sourceColumn: "Filter 2 Feed Pressure" },
                        { label: "Feed Flow", location: "Filter 2", metricType: "Feed Flow", sourceColumn: "Filter 2 Feed Flow" },
                        { label: "Filtrate Pressure", location: "Filter 2", metricType: "Filtrate Pressure", sourceColumn: "Filter 2 Filtrate Pressure" },
                        { label: "Filtrate Flow", location: "Filter 2", metricType: "Filtrate Flow", sourceColumn: "Filter 2 Filtrate Flow" },
                        { label: "TMP", location: "Filter 2", metricType: "TMP", sourceColumn: "Filter 2 TMP" },
                        { label: "Total Filter Run Time", location: "Filter 2", metricType: "Total Filter Run Time", sourceColumn: "Filter 2 Total Filter Run Time" },
                        { label: "Total Filtration Flow Yesterday", location: "Filter 2", metricType: "Total Filtration Flow Yesterday", sourceColumn: "Filter 2 Total Filtration Flow Yesterday" },
                        { label: "Pressure Decay", location: "Filter 2", metricType: "Pressure Decay", sourceColumn: "Filter 2 Pressure Decay" }
                    ]
                },
                {
                    title: "Plant Readings",
                    fields: [
                        { label: "Meter Reading", location: "Filter Plant", metricType: "Meter Reading", sourceColumn: "Filter Plant" },
                        { label: "Chlorine", location: "Filter Plant", metricType: "Chlorine", sourceColumn: "Cl-F" },
                        { label: "Phosphate", location: "Filter Plant", metricType: "Phosphate", sourceColumn: "PO4-F" },
                        { label: "Temperature", location: "Filter Plant", metricType: "Temperature", sourceColumn: "Temp-F" },
                        { label: "Mt. Jefferson", location: "Mt. Jefferson", metricType: "Meter Reading", sourceColumn: "Mt. Jefferson" }
                    ]
                }
            ]
        },
        {
            name: "Pump Stations",
            displayName: "Pumps",
            groups: [
                {
                    title: "Beaver Creek",
                    fields: [
                        { label: "Pump 1", location: "Beaver Creek Pump 1", metricType: "Pump Status", sourceColumn: "Beaver Creek Pump 1" },
                        { label: "Pump 2", location: "Beaver Creek Pump 2", metricType: "Pump Status", sourceColumn: "Beaver Creek Pump 2" },
                        { label: "Generator", location: "Beaver Creek Generator", metricType: "Generator Status", sourceColumn: "Beaver Creek Generator" }
                    ]
                },
                {
                    title: "Greenfield",
                    fields: [
                        { label: "Pump 1", location: "Greenfield Pump 1", metricType: "Pump Status", sourceColumn: "Greenfield Pump 1" },
                        { label: "Pump 2", location: "Greenfield Pump 2", metricType: "Pump Status", sourceColumn: "Greenfield Pump 2" },
                        { label: "Generator", location: "Greenfield Generator", metricType: "Generator Status", sourceColumn: "Greenfield Generator" }
                    ]
                },
                {
                    title: "Helen Blevins",
                    fields: [
                        { label: "Pump 1", location: "Helen Blevins Pump 1", metricType: "Pump Status", sourceColumn: "Helen Blevins Pump 1" },
                        { label: "Pump 2", location: "Helen Blevins Pump 2", metricType: "Pump Status", sourceColumn: "Helen Blevins Pump 2" }
                    ]
                },
                {
                    title: "Dogget",
                    fields: [
                        { label: "Pump 1", location: "Dogget Pump 1", metricType: "Pump Status", sourceColumn: "Dogget Pump 1" },
                        { label: "Pump 2", location: "Dogget Pump 2", metricType: "Pump Status", sourceColumn: "Dogget Pump 2" }
                    ]
                }
            ]
        }
    ];

    const values = {};
    let currentSiteName = null;
    let runningStatuses = {};

    document.getElementById("entryDate").valueAsDate = new Date();

    function storageKey() {
        const date = document.getElementById("entryDate").value || "no-date";
        return `scada-entry-draft-${date}`;
    }

    function saveDraft() {
        localStorage.setItem(storageKey(), JSON.stringify(values));
    }

    function loadDraft() {
        document.getElementById("draftNotice").style.display = "none";

        const saved = localStorage.getItem(storageKey());

        if (!saved) return;

        try {
            const draft = JSON.parse(saved);

            Object.keys(draft).forEach(key => {
                values[key] = draft[key];
            });

            document.getElementById("draftNotice").style.display = "block";
        } catch {
            localStorage.removeItem(storageKey());
        }
    }

    function clearDraft() {
        localStorage.removeItem(storageKey());
        document.getElementById("draftNotice").style.display = "none";
    }

    function keyFor(field) {
        return `${field.location}|${field.metricType}|${field.sourceColumn}`;
    }

    function getAllFields(site) {
        if (site.groups) {
            return site.groups.flatMap(group => group.fields);
        }

        return site.fields;
    }

    function buildTiles() {
        const container = document.getElementById("siteTiles");
        container.innerHTML = "";

        sites.forEach(site => {
            const div = document.createElement("div");
            div.className = "site-tile";
            div.id = `tile-${site.name}`;
            div.innerText = site.displayName;
            div.onclick = () => openSite(site.name);
            container.appendChild(div);
        });

        refreshAllTileStatuses();
    }

    function openSite(siteName) {
        currentSiteName = siteName;

        const site = sites.find(x => x.name === siteName);
        const panel = document.getElementById("entryPanel");

        if (!site) return;

        panel.style.display = "block";

        if (site.groups) {
            panel.innerHTML = `
                <h2>${site.displayName}</h2>

                ${site.groups.map((group, index) => `
                    <div class="entry-group">
                        <div class="group-header" onclick="toggleGroup('${site.name}-group-${index}')">
                            ${group.title} ▼
                        </div>

                        <div class="group-body" id="${site.name}-group-${index}">
                            ${group.fields.map(field => renderField(site, field)).join("")}
                        </div>
                    </div>
                `).join("")}
            `;
        } else {
            panel.innerHTML = `
                <h2>${site.displayName}</h2>
                ${site.fields.map(field => renderField(site, field)).join("")}
            `;
        }
    }

    function renderField(site, field) {
        const key = keyFor(field);
        const savedValue = values[key] ?? "";

        return `
            <div class="field-row">
                <label>${field.label}</label>
                <input
                    type="number"
                    inputmode="decimal"
                    pattern="[0-9]*"
                    step="0.01"
                    value="${savedValue}"
                    data-site="${site.name}"
                    data-location="${field.location}"
                    data-metric="${field.metricType}"
                    data-source="${field.sourceColumn}"
                    oninput="saveValueFromInput(this)" />
            </div>
        `;
    }

    function toggleGroup(id) {
        const group = document.getElementById(id);
        if (!group) return;
        group.classList.toggle("collapsed");
    }

    function saveValueFromInput(input) {
        const key = `${input.dataset.location}|${input.dataset.metric}|${input.dataset.source}`;
        values[key] = input.value;

        saveDraft();
        markTileStatus(input.dataset.site);
    }

    function markTileStatus(siteName) {
        const site = sites.find(x => x.name === siteName);
        const tile = document.getElementById(`tile-${siteName}`);

        if (!site || !tile) return;

        tile.classList.remove("complete", "running");

        const isRunning =
            runningStatuses[site.name] ||
            (site.name === "Filter Plant" && (runningStatuses["Filter 1"] || runningStatuses["Filter 2"]));

        const hasAnyValue = getAllFields(site).some(field => {
            const key = keyFor(field);
            return values[key] !== undefined && values[key] !== "";
        });

        if (isRunning) {
            tile.classList.add("running");
        } else if (hasAnyValue) {
            tile.classList.add("complete");
        }
    }

    function refreshAllTileStatuses() {
        sites.forEach(site => markTileStatus(site.name));
    }

    async function loadRunningStatuses() {
        const response = await fetch("/api/maintenance/site-statuses");

        if (!response.ok) return;

        const statuses = await response.json();
        runningStatuses = {};

        statuses.forEach(status => {
            runningStatuses[status.siteName] = status.isOn;
        });

        refreshAllTileStatuses();
    }

    async function handleDateChange() {
        await loadExistingEntry();
    }

    async function loadExistingEntry() {
        const date = document.getElementById("entryDate").value;

        if (!date) return;

        Object.keys(values).forEach(key => delete values[key]);

        const response = await fetch(`/api/scada/entry-by-date?date=${date}`);

        if (response.ok) {
            const entries = await response.json();

            entries.forEach(item => {
                const key = `${item.location}|${item.metricType}|${item.sourceColumn}`;
                values[key] = item.value;
            });

            document.getElementById("lockedNotice").style.display =
                entries.length > 0 ? "block" : "none";

            document.getElementById("message").innerText =
                entries.length > 0 ? "Existing entry loaded." : "No entry found for this date.";
        }

        loadDraft();
        refreshAllTileStatuses();

        if (currentSiteName) {
            openSite(currentSiteName);
        }
    }

    async function submitReadings() {
        const selectedDate = document.getElementById("entryDate").value;

        if (!selectedDate) {
            alert("Please select a reading date.");
            return;
        }

        const now = new Date();
        const currentTime =
            now.getHours().toString().padStart(2, "0") + ":" +
            now.getMinutes().toString().padStart(2, "0") + ":" +
            now.getSeconds().toString().padStart(2, "0");

        const timestamp = `${selectedDate}T${currentTime}`;

        const readings = [];

        Object.keys(values).forEach(key => {
            const value = values[key];

            if (value === "") return;

            const parts = key.split("|");

            readings.push({
                timestamp: timestamp,
                location: parts[0],
                metricType: parts[1],
                sourceColumn: parts[2],
                value: parseFloat(value)
            });
        });

        if (readings.length === 0) {
            alert("Please enter at least one reading.");
            return;
        }

        const existingResponse = await fetch(`/api/scada/entry-by-date?date=${selectedDate}`);
        const existingEntries = existingResponse.ok ? await existingResponse.json() : [];

        if (existingEntries.length > 0) {
            const confirmOverwrite = confirm("This date already has readings. Submit anyway and overwrite that date?");
            if (!confirmOverwrite) return;
        }

        const response = await fetch("/api/scada/manual-entry", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(readings)
        });

        const message = document.getElementById("message");

        if (response.ok) {
            clearDraft();
            message.innerText = "Readings saved successfully.";
            message.style.color = "#047857";
            document.getElementById("lockedNotice").style.display = "block";
            refreshAllTileStatuses();
        } else {
            message.innerText = "Error saving readings.";
            message.style.color = "#b91c1c";
        }
    }

    buildTiles();
    loadRunningStatuses();
    loadExistingEntry();
</script>
