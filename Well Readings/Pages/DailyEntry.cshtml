@page
@model Well_Readings.Pages.DailyEntriesModel

<h1>Daily Entries</h1>

<table class="entry-table">
    <thead>
        <tr>
            <th>Date / Time</th>
            <th>Number of Readings</th>
        </tr>
    </thead>
    <tbody id="entriesBody"></tbody>
</table>

<style>
    .entry-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        color: #111827;
    }

        .entry-table th,
        .entry-table td {
            border: 1px solid #d1d5db;
            padding: 10px;
            text-align: left;
        }

        .entry-table th {
            background: #1f2937;
            color: white;
        }

        .entry-table a {
            color: #2563eb;
            font-weight: bold;
            text-decoration: none;
        }

            .entry-table a:hover {
                text-decoration: underline;
            }
</style>

<script>
    async function loadEntries() {
        const response = await fetch("/api/scada/daily-entries");
        const entries = await response.json();

        const body = document.getElementById("entriesBody");
        body.innerHTML = "";

        entries.forEach(entry => {
            const timestamp = entry.timestamp;
            const displayDate = new Date(timestamp).toLocaleString();

            const row = document.createElement("tr");

            row.innerHTML = `
                <td>
                    <a href="/DailyEntryEdit?timestamp=${encodeURIComponent(timestamp)}">
                        ${displayDate}
                    </a>
                </td>
                <td>${entry.count}</td>
            `;

            body.appendChild(row);
        });
    }

    loadEntries();
</script>