@page "/DailyEntry"
@model Well_Readings.Pages.DailyEntriesModel

<h1>Daily Entry Log</h1>

<button type="button" class="delete-btn" onclick="deleteSelectedEntries()">
    Delete Selected
</button>

<table class="entry-table">
    <thead>
        <tr>
            <th>Select</th>
            <th>Date / Time</th>
            <th>Number of Readings</th>
        </tr>
    </thead>
    <tbody id="entriesBody"></tbody>
</table>

<div id="message"></div>

<style>
    .delete-btn {
        background: #dc2626;
        color: white;
        padding: 10px 18px;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        margin-bottom: 15px;
    }

    .entry-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        color: #111827;
    }

        .entry-table th,
        .entry-table td {
            border: 1px solid #d1d5db;
            padding: 10px;
            text-align: left;
        }

        .entry-table th {
            background: #1f2937;
            color: white;
        }

        .entry-table tbody tr:nth-child(even) {
            background: #eff6ff;
        }

        .entry-table a {
            color: #2563eb;
            font-weight: bold;
            text-decoration: none;
        }

    #message {
        margin-top: 15px;
        font-weight: bold;
    }
</style>

<script>
    async function loadEntries() {
        const response = await fetch("/api/scada/daily-entries");
        const entries = await response.json();

        const body = document.getElementById("entriesBody");
        body.innerHTML = "";

        entries.forEach(entry => {
            const row = document.createElement("tr");
            const dateOnly = entry.date || entry.timestamp;

            row.innerHTML = `
                <td>
                    <input type="checkbox" class="entry-check" value="${dateOnly}" />
                </td>
                <td>
                    <a href="/DailyEntryEdit?timestamp=${encodeURIComponent(entry.timestamp)}">
                        ${new Date(entry.timestamp).toLocaleString()}
                    </a>
                </td>
                <td>${entry.count}</td>
            `;

            body.appendChild(row);
        });
    }

    async function deleteSelectedEntries() {
        const checked = Array.from(document.querySelectorAll(".entry-check:checked"));

        if (checked.length === 0) {
            alert("Select at least one entry to delete.");
            return;
        }

        if (!confirm("Delete the selected daily entries?")) {
            return;
        }

        const dates = checked.map(x => x.value);

        const response = await fetch("/api/scada/daily-entry/delete", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ dates: dates })
        });

        const message = document.getElementById("message");

        if (response.ok) {
            message.innerText = "Selected entries deleted.";
            message.style.color = "#047857";
            loadEntries();
        } else {
            message.innerText = "Error deleting entries.";
            message.style.color = "#b91c1c";
        }
    }

    loadEntries();
</script>