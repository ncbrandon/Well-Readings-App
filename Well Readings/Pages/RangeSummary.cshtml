@page
@model Well_Readings.Pages.RangeSummaryModel

<h2>Range Summary</h2>

<form method="get">
    <label>Start Date:</label>
    <input type="date" name="startDate" />

    <label>End Date:</label>
    <input type="date" name="endDate" />

    <button type="submit">Load</button>
</form>

<hr />

@if (Model.Rows != null && Model.Rows.Any())
{
    <p><strong>Total Gallons (All Sites):</strong> @Model.TotalGallonsAllSites</p>
    <table class="table">
        <thead>
            <tr>
                <th>Well</th>
                <th>Total Production</th>
                <th>Min Reading</th>
                <th>Max Reading</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.WellName</td>
                    <td>@row.TotalProduction</td>
                    <td>@row.MinReading</td>
                    <td>@row.MaxReading</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No data found.</p>
}
